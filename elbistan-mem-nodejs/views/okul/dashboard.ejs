<%- include('../layouts/school_header') %>

    <link rel="stylesheet" href="/css/okul_dashboard.css">

    <div class="dashboard-container">

        <!-- Header -->
        <div class="page-header-compact">
            <h1><i class="fas fa-school" style="color: #E31E24;"></i> Kurum Yönetim Paneli</h1>
            <span class="header-date" id="headerDate"></span>
        </div>

        <!-- Bilgi Kutuları Bölümü -->
        <div class="section-card" style="margin-bottom: 25px;">
            <div class="section-header">
                <div class="section-title">
                    <i class="fas fa-info-circle"></i> Bilgi Kutuları
                </div>
            </div>
            <div class="section-body" style="padding: 20px;">
                <div class="stats-grid" style="margin-bottom: 0;">
                    <div class="stat-card blue">
                        <div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
                        <div class="stat-value"><%= totalTasks %></div>
                        <div class="stat-label">Toplam Görev</div>
                    </div>
                    <div class="stat-card red">
                        <div class="stat-icon"><i class="fas fa-hourglass-start"></i></div>
                        <div class="stat-value"><%= pendingTasks %></div>
                        <div class="stat-label">Bekleyen (İşlemsiz)</div>
                    </div>
                    <div class="stat-card yellow">
                        <div class="stat-icon"><i class="fas fa-spinner"></i></div>
                        <div class="stat-value"><%= inProgressTasks %></div>
                        <div class="stat-label">İşlemde</div>
                    </div>
                    <div class="stat-card green">
                        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                        <div class="stat-value"><%= completedTasks %></div>
                        <div class="stat-label">Tamamlanan</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="main-grid">
            <!-- Sol Kolon: Duyurular ve Görevler -->
            <div class="left-col">
                <% if(announcement) { %>
                    <div class="announcement-card">
                        <div class="announcement-title"><i class="fas fa-bullhorn"></i>
                            <%= announcement.title %>
                        </div>
                        <p class="announcement-text">
                            <%= announcement.content %>
                        </p>
                    </div>
                    <% } %>

                        <div class="section-card">
                            <div class="section-header">
                                <div class="section-title"><i class="fas fa-tasks" style="color: #E31E24;"></i> Görev
                                    Listesi</div>
                            </div>

                            <div class="task-list-container">
                                <% if(myTasks.length === 0) { %>
                                    <div style="padding: 40px; text-align: center; color: #9ca3af;">
                                        <i class="fas fa-inbox"
                                            style="font-size: 32px; margin-bottom: 10px; color: #d1d5db;"></i>
                                        <p>Henüz atanmış bir görev bulunmuyor.</p>
                                    </div>
                                <% } else { %>
                                    <% myTasks.forEach(task => { %>
                                        <% 
                                            let isExpired = false;
                                            if (task.deadline && task.status !== 'completed' && task.status !== 'rejected') {
                                                const dDate = new Date(task.deadline);
                                                if (task.deadline.length <= 10) dDate.setHours(23, 59, 59, 999);
                                                if (new Date() > dDate) isExpired = true;
                                            }
                                        %>
                                        <a href="/okul/tasks/<%= task.assignment_id %>"
                                            class="task-item status-<%= task.status %> <%= isExpired ? 'expired' : '' %>">
                                            <div class="task-icon-box">
                                                <% if(task.status === 'pending') { %>
                                                    <i class="fas fa-exclamation"></i>
                                                <% } else if(task.status === 'in_progress') { %>
                                                    <i class="fas fa-spinner fa-spin"></i>
                                                <% } else if(task.status === 'rejected') { %>
                                                    <i class="fas fa-undo"></i>
                                                <% } else { %>
                                                    <i class="fas fa-check"></i>
                                                <% } %>
                                            </div>
                                            <div class="task-content">
                                                <div class="task-title" style="<%= isExpired ? 'color: #94a3b8;' : '' %>">
                                                    <%= task.title %>
                                                    <% if(task.status === 'rejected') { %>
                                                        <span class="badge-rejected">İADE</span>
                                                    <% } else if (isExpired) { %>
                                                        <span class="badge-expired" style="background: #94a3b8; color: white; font-size: 9px; padding: 2px 6px; border-radius: 4px; font-weight: 700; margin-left: 8px;">SÜRE DOLDU</span>
                                                    <% } else if(task.status === 'pending' && !task.is_read) { %>
                                                        <span class="badge-new">YENİ</span>
                                                    <% } %>
                                                </div>
                                                <div class="task-meta">
                                                    <span style="<%= isExpired ? 'color: #ef4444; font-weight: 700;' : '' %>">
                                                        <i class="far fa-calendar"></i> Son Tarih: <%= task.deadline || 'Belirtilmemiş' %>
                                                        <% if(isExpired) { %> (Süre Doldu) <% } %>
                                                    </span>
                                                </div>
                                            </div>
                                            <% if(task.status !== 'rejected' && !isExpired) { %>
                                                <span class="status-dot dot-<%= task.status %>"></span>
                                            <% } %>
                                            <i class="fas fa-chevron-right" style="color: #9ca3af; font-size: 12px;"></i>
                                        </a>
                                    <% }) %>
                                <% } %>
                            </div>
                        </div>
            </div>

            <!-- Sağ Kolon: Takvim ve Dosyalar -->
            <div class="right-col">
                <div class="calendar-widget" style="overflow: visible; padding: 0;">
                    <div class="cal-header"
                        style="padding: 16px 18px; background: var(--gray-50); border-bottom: 1px solid var(--gray-200); display: flex; justify-content: space-between; align-items: center;">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <div
                                style="width: 32px; height: 32px; background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-calendar-alt" style="color: #E31E24; font-size: 14px;"></i>
                            </div>
                            <span class="cal-month" id="calMonthYear"
                                style="font-weight: 700; color: var(--gray-800); font-size: 15px;"></span>
                        </div>
                        <div style="display: flex; gap: 5px; align-items: center;">
                            <button onclick="calChangeMonth(-1)"
                                style="width: 30px; height: 30px; border-radius: 8px; border: 1px solid #e2e8f0; background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #64748b; transition: all 0.2s;"
                                onmouseover="this.style.background='#E31E24'; this.style.color='white'; this.style.borderColor='#E31E24';"
                                onmouseout="this.style.background='white'; this.style.color='#64748b'; this.style.borderColor='#e2e8f0';">
                                <i class="fas fa-chevron-left" style="font-size: 11px;"></i>
                            </button>
                            <button onclick="calGoToday()"
                                style="padding: 5px 12px; border-radius: 8px; border: 1px solid #e2e8f0; background: white; cursor: pointer; font-size: 11px; font-weight: 600; color: #64748b; transition: all 0.2s; font-family: inherit;"
                                onmouseover="this.style.background='#1e293b'; this.style.color='white'; this.style.borderColor='#1e293b';"
                                onmouseout="this.style.background='white'; this.style.color='#64748b'; this.style.borderColor='#e2e8f0';">
                                Bugün
                            </button>
                            <button onclick="calChangeMonth(1)"
                                style="width: 30px; height: 30px; border-radius: 8px; border: 1px solid #e2e8f0; background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #64748b; transition: all 0.2s;"
                                onmouseover="this.style.background='#E31E24'; this.style.color='white'; this.style.borderColor='#E31E24';"
                                onmouseout="this.style.background='white'; this.style.color='#64748b'; this.style.borderColor='#e2e8f0';">
                                <i class="fas fa-chevron-right" style="font-size: 11px;"></i>
                            </button>
                        </div>
                    </div>
                    <div class="cal-grid" id="schoolCalendar" data-events="<%= calendarEvents %>"></div>
                    <!-- Yaklaşan Görevler -->
                    <div id="schoolUpcomingTasks" style="padding: 0 18px 16px; border-top: 1px solid #f1f5f9;">
                        <div
                            style="font-size: 11px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; margin: 12px 0 8px; display: flex; align-items: center; gap: 6px;">
                            <i class="fas fa-clock" style="font-size: 10px;"></i> Yaklaşan Teslim Tarihleri
                        </div>
                        <div id="schoolUpcomingList"></div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <div class="section-title"><i class="fas fa-folder-open"></i> Sabit Dosyalar</div>
                    </div>
                    <div style="padding: 15px;">
                        <% if(systemFiles.length===0) { %>
                            <div style="text-align: center; color: #9ca3af; padding: 30px; font-size: 13px;">
                                <i class="fas fa-folder-open"
                                    style="font-size: 28px; margin-bottom: 10px; display: block; color: #d1d5db;"></i>
                                Dosya eklenmemiş.
                            </div>
                            <% } else { %>
                                <% systemFiles.forEach(file=> { %>
                                    <a href="/uploads/system/<%= file.file_path %>" target="_blank"
                                        style="display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-radius: 10px; text-decoration: none; color: #1f2937; transition: all 0.2s ease; margin-bottom: 8px; border: 1px solid #e5e7eb; background: #f9fafb;"
                                        onmouseover="this.style.background='#f3f4f6'; this.style.borderColor='#d1d5db';"
                                        onmouseout="this.style.background='#f9fafb'; this.style.borderColor='#e5e7eb';">
                                        <div
                                            style="width: 36px; height: 36px; background: #fef2f2; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                            <i class="fas fa-file-pdf" style="color: #dc2626; font-size: 14px;"></i>
                                        </div>
                                        <span style="font-size: 13px; flex: 1; font-weight: 500;">
                                            <%= file.title %>
                                        </span>
                                        <div
                                            style="width: 28px; height: 28px; background: #dbeafe; border-radius: 6px; display: flex; align-items: center; justify-content: center;">
                                            <i class="fas fa-download" style="color: #2563eb; font-size: 11px;"></i>
                                        </div>
                                    </a>
                                    <% }) %>
                                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/okul_dashboard.js"></script>

    <%- include('../layouts/school_footer') %>