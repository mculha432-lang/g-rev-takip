<%- include('../layouts/school_header') %>

    <link rel="stylesheet" href="/css/okul_task_detail.css">

    <div class="page-header">
        <div class="page-header-left">
            <div class="page-header-icon"><i class="fas fa-tasks"></i></div>
            <div>
                <h1>Görev Detayı</h1>
                <p>Görevi inceleyin ve yanıtınızı gönderin.</p>
            </div>
        </div>
        <a href="/okul/dashboard" class="btn-back"><i class="fas fa-arrow-left"></i> Geri Dön</a>
    </div>

    <% const statusMessages={ 'success' : { updated: 'Yanıtınız başarıyla kaydedildi.' ,
        message_sent: 'Mesajınız gönderildi.' }, 'error' : { missing_file: 'Lütfen bir dosya yükleyin.' ,
        empty_message: 'Mesaj boş olamaz.' , '1' : 'Bir hata oluştu, lütfen tekrar deneyin.' } }; %>

        <% if (typeof success !=='undefined' && success) { %>
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i>
                <%= success==='updated' ? 'Yanıtınız başarıyla kaydedildi.' : success==='message_sent'
                    ? 'Mesajınız gönderildi.' : 'İşlem başarılı.' %>
            </div>
            <% } %>
                <% if (typeof error !=='undefined' && error) { %>
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle"></i>
                        <%= error==='missing_file' ? 'Lütfen bir dosya yükleyin.' : error==='already_submitted'
                            ? 'Bu görev zaten onaya gönderilmiş veya tamamlanmış. Değişiklik yapmak için yöneticiden İade istemeniz gerekmektedir.'
                            : error==='deadline_passed'
                            ? 'Bu görevin süresi dolmuştur. İşlem yapmak için yönetici tarafından İade (Tekrar düzenleme izni) verilmesi gerekmektedir.'
                            : error==='empty_message' ? 'Mesaj boş olamaz.' : 'Bir hata oluştu, lütfen tekrar deneyin.'
                            %>
                    </div>
                    <% } %>

                        <% if (typeof isDeadlinePassed !=='undefined' && isDeadlinePassed) { %>
                            <div class="alert alert-warning"
                                style="background:#fff7ed; color:#c2410c; border-color:#fed7aa;">
                                <i class="fas fa-clock"></i>
                                <strong>Süre Doldu:</strong> Bu görevin son teslim tarihi geçmiştir. Yönetici iade
                                etmediği sürece herhangi bir değişiklik yapamazsınız. Detaylar için mesajlaşma kısmından
                                yöneticinize ulaşabilirsiniz.
                            </div>
                            <% } %>

                                <!-- Görev Bilgisi -->
                                <div class="task-card">
                                    <div class="task-title"><i class="fas fa-clipboard-list"
                                            style="color:var(--red); margin-right:10px;"></i>
                                        <%= task.title %>
                                    </div>

                                    <% if (task.description) { %>
                                        <div class="task-desc"><%- task.description %></div>
                                        <% } %>

                                            <div class="task-meta">
                                                <div class="task-meta-item">
                                                    <i class="fas fa-info-circle"></i>
                                                    <div>
                                                        <span
                                                            style="display:block;font-size:11px;color:var(--gray-600);font-weight:500;">Durum</span>
                                                        <% if (task.status==='completed' ) { %>
                                                            <span class="badge badge-completed"><i
                                                                    class="fas fa-check"></i> Tamamlandı</span>
                                                            <% } else if (task.status==='pending_approval' ) { %>
                                                                <span class="badge badge-pending_approval"><i
                                                                        class="fas fa-hourglass-half"></i> Onay
                                                                    Bekliyor</span>
                                                                <% } else if (task.status==='in_progress' ) { %>
                                                                    <span class="badge badge-in_progress"><i
                                                                            class="fas fa-spinner fa-spin"></i> Devam
                                                                        Ediyor</span>
                                                                    <% } else if (task.status==='rejected' ) { %>
                                                                        <span class="badge badge-rejected"><i
                                                                                class="fas fa-times"></i> İade
                                                                            Edildi</span>
                                                                        <% } else { %>
                                                                            <span class="badge badge-pending"><i
                                                                                    class="fas fa-clock"></i>
                                                                                Bekliyor</span>
                                                                            <% } %>
                                                    </div>
                                                </div>

                                                <% if (task.deadline) { %>
                                                    <div class="task-meta-item">
                                                        <i class="fas fa-calendar-alt"></i>
                                                        <div>
                                                            <span
                                                                style="display:block;font-size:11px;color:var(--gray-600);font-weight:500;">Son
                                                                Teslim</span>
                                                            <%= task.deadline %>
                                                        </div>
                                                    </div>
                                                    <% } %>

                                                        <% if (task.task_file) { %>
                                                            <div class="task-meta-item">
                                                                <i class="fas fa-file-alt"></i>
                                                                <div>
                                                                    <span
                                                                        style="display:block;font-size:11px;color:var(--gray-600);font-weight:500;">Ekli
                                                                        Dosya</span>
                                                                    <a href="/uploads/tasks/<%= task.task_file %>"
                                                                        target="_blank"
                                                                        style="color: var(--red); text-decoration:none; font-weight:600;">
                                                                        <i class="fas fa-download"></i> İndir
                                                                    </a>
                                                                </div>
                                                            </div>
                                                            <% } %>
                                            </div>
                                </div>

                                <!-- İade Notu (varsa) -->
                                <% if (task.status==='rejected' && task.rejection_note) { %>
                                    <div class="rejection-box">
                                        <h4><i class="fas fa-exclamation-triangle"></i> İade Sebebi</h4>
                                        <p>
                                            <%= task.rejection_note %>
                                        </p>
                                    </div>
                                    <% } %>

                                        <!-- Yanıt Formu -->
                                        <% if (task.status !=='completed' && task.status !=='pending_approval' &&
                                            !isDeadlinePassed) { %>
                                            <div class="section-card">
                                                <div class="section-header">
                                                    <i class="fas fa-paper-plane"></i>
                                                    <%= task.status==='rejected' ? 'Tekrar Yanıt Gönder'
                                                        : 'Yanıt Gönder' %>
                                                </div>
                                                <div class="section-body">

                                                    <% if (task.response_file) { %>
                                                        <div class="response-display" style="margin-bottom: 20px;">
                                                            <p><strong><i class="fas fa-paperclip"></i> Mevcut Yanıt
                                                                    Dosyası:</strong></p>
                                                            <a href="/uploads/responses/<%= task.response_file %>"
                                                                target="_blank">
                                                                <i class="fas fa-file"></i> Dosyayı Görüntüle
                                                            </a>
                                                        </div>
                                                        <% } %>

                                                            <form action="/okul/tasks/<%= task.id %>/response"
                                                                method="POST" enctype="multipart/form-data">
                                                                <input type="hidden" name="_csrf"
                                                                    value="<%= csrfToken %>">

                                                                <% if (taskFields && taskFields.length> 0) { %>
                                                                    <% taskFields.forEach(field=> { %>
                                                                        <div class="field-group">
                                                                            <label class="field-label">
                                                                                <%= field.field_label %>
                                                                                    <% if (field.is_required) { %><span
                                                                                            class="required">*</span>
                                                                                        <% } %>
                                                                            </label>

                                                                            <% if (field.field_type==='short_text' ||
                                                                                field.field_type==='text' ) { %>
                                                                                <input type="text"
                                                                                    name="field_<%= field.id %>"
                                                                                    class="form-control"
                                                                                    placeholder="Yanıtınızı yazın..."
                                                                                    value="<%= responsesMap[field.id] || '' %>"
                                                                                    <%=field.is_required ? 'required'
                                                                                    : '' %>>

                                                                                <% } else if
                                                                                    (field.field_type==='paragraph' ||
                                                                                    field.field_type==='textarea' ) { %>
                                                                                    <textarea
                                                                                        name="field_<%= field.id %>"
                                                                                        class="form-control"
                                                                                        placeholder="Yanıtınızı yazın..."
                                                                                        <%=field.is_required
                                                                                        ? 'required' : ''
                                                                                        %>><%= responsesMap[field.id] || '' %></textarea>

                                                                                    <% } else if
                                                                                        (field.field_type==='multiple_choice'
                                                                                        || field.field_type==='radio' )
                                                                                        { %>
                                                                                        <div class="options-group">
                                                                                            <% if (field.field_options)
                                                                                                { %>
                                                                                                <%
                                                                                                    field.field_options.split(',').forEach(opt=>
                                                                                                    { %>
                                                                                                    <% const
                                                                                                        optVal=opt.trim();
                                                                                                        if(!optVal)
                                                                                                        return; %>
                                                                                                        <div
                                                                                                            class="option-item">
                                                                                                            <input
                                                                                                                type="radio"
                                                                                                                name="field_<%= field.id %>"
                                                                                                                id="r_<%= field.id %>_<%= optVal %>"
                                                                                                                value="<%= optVal %>"
                                                                                                                <%=responsesMap[field.id]===optVal
                                                                                                                ? 'checked'
                                                                                                                : '' %>
                                                                                                            <%= field.is_required
                                                                                                                ? 'required'
                                                                                                                : '' %>>
                                                                                                                <label
                                                                                                                    for="r_<%= field.id %>_<%= optVal %>">
                                                                                                                    <%= optVal
                                                                                                                        %>
                                                                                                                </label>
                                                                                                        </div>
                                                                                                        <% }) %>
                                                                                                            <% } %>
                                                                                        </div>

                                                                                        <% } else if
                                                                                            (field.field_type==='select'
                                                                                            ) { %>
                                                                                            <select
                                                                                                name="field_<%= field.id %>"
                                                                                                class="form-control"
                                                                                                <%=field.is_required
                                                                                                ? 'required' : '' %>>
                                                                                                <option value="">--
                                                                                                    Seçiniz --</option>
                                                                                                <% if
                                                                                                    (field.field_options)
                                                                                                    { %>
                                                                                                    <%
                                                                                                        field.field_options.split(',').forEach(opt=>
                                                                                                        { %>
                                                                                                        <% const
                                                                                                            optVal=opt.trim();
                                                                                                            if(!optVal)
                                                                                                            return; %>
                                                                                                            <option
                                                                                                                value="<%= optVal %>"
                                                                                                                <%=responsesMap[field.id]===optVal
                                                                                                                ? 'selected'
                                                                                                                : '' %>>
                                                                                                                <%= optVal
                                                                                                                    %>
                                                                                                            </option>
                                                                                                            <% }) %>
                                                                                                                <% } %>
                                                                                            </select>

                                                                                            <% } else if
                                                                                                (field.field_type==='checkbox'
                                                                                                ) { %>
                                                                                                <div
                                                                                                    class="options-group">
                                                                                                    <% if
                                                                                                        (field.field_options)
                                                                                                        { %>
                                                                                                        <% const
                                                                                                            checkedVals=(responsesMap[field.id]
                                                                                                            ?
                                                                                                            String(responsesMap[field.id])
                                                                                                            : ''
                                                                                                            ).split(', '); %>
                                <% field.field_options.split(' ,').forEach(opt=> { %>
                                                                                                            <% const
                                                                                                                optVal=opt.trim();
                                                                                                                if(!optVal)
                                                                                                                return;
                                                                                                                %>
                                                                                                                <div
                                                                                                                    class="option-item">
                                                                                                                    <input
                                                                                                                        type="checkbox"
                                                                                                                        name="field_<%= field.id %>"
                                                                                                                        id="c_<%= field.id %>_<%= optVal %>"
                                                                                                                        value="<%= optVal %>"
                                                                                                                        <%=checkedVals.includes(optVal)
                                                                                                                        ? 'checked'
                                                                                                                        : ''
                                                                                                                        %>>
                                                                                                                    <label
                                                                                                                        for="c_<%= field.id %>_<%= optVal %>">
                                                                                                                        <%= optVal
                                                                                                                            %>
                                                                                                                    </label>
                                                                                                                </div>
                                                                                                                <% }) %>
                                                                                                                    <% }
                                                                                                                        %>
                                                                                                </div>

                                                                                                <% } else if
                                                                                                    (field.field_type==='number'
                                                                                                    ) { %>
                                                                                                    <input type="number"
                                                                                                        name="field_<%= field.id %>"
                                                                                                        class="form-control"
                                                                                                        value="<%= responsesMap[field.id] || '' %>"
                                                                                                        <%=field.is_required
                                                                                                        ? 'required'
                                                                                                        : '' %>>

                                                                                                    <% } else if
                                                                                                        (field.field_type==='date'
                                                                                                        ) { %>
                                                                                                        <input
                                                                                                            type="date"
                                                                                                            name="field_<%= field.id %>"
                                                                                                            class="form-control"
                                                                                                            value="<%= responsesMap[field.id] || '' %>"
                                                                                                            <%=field.is_required
                                                                                                            ? 'required'
                                                                                                            : '' %>>

                                                                                                        <% } else if (field.field_type==='time') { %>
                                                                                                        <input
                                                                                                            type="time"
                                                                                                            name="field_<%= field.id %>"
                                                                                                            class="form-control"
                                                                                                            value="<%= responsesMap[field.id] || '' %>"
                                                                                                            <%=field.is_required
                                                                                                            ? 'required'
                                                                                                            : '' %>>

                                                                                                        <% } else if (field.field_type==='scale') { %>
                                                                                                        <div class="scale-group" style="display:flex; gap:12px; flex-wrap:wrap; margin-top:8px;">
                                                                                                            <% for(let i = 1; i <= 5; i++) { %>
                                                                                                            <label class="scale-option" style="display:flex; flex-direction:column; align-items:center; cursor:pointer;">
                                                                                                                <input type="radio" name="field_<%= field.id %>" value="<%= i %>"
                                                                                                                    <%= responsesMap[field.id] == String(i) ? 'checked' : '' %>
                                                                                                                    <%= field.is_required ? 'required' : '' %>
                                                                                                                    style="width:20px; height:20px; accent-color:var(--red);">
                                                                                                                <span style="font-size:13px; font-weight:600; margin-top:4px;"><%= i %></span>
                                                                                                            </label>
                                                                                                            <% } %>
                                                                                                        </div>
                                                                                                        <% } %>
                                                                        </div>
                                                                        <% }) %>
                                                                            <% } %>

                                                                                <div class="field-group">
                                                                                    <label class="field-label">Yanıt
                                                                                        Notu <span
                                                                                            style="font-size:12px; color:var(--gray-400); font-weight:400;">(isteğe
                                                                                            bağlı)</span></label>
                                                                                    <textarea name="response_note"
                                                                                        class="form-control"
                                                                                        placeholder="Açıklamalarınızı buraya yazabilirsiniz..."><%= task.response_note || '' %></textarea>
                                                                                </div>

                                                                                <% if (task.requires_file) { %>
                                                                                    <div class="field-group">
                                                                                        <label class="field-label">
                                                                                            Yanıt Dosyaları
                                                                                            <% if
                                                                                                (task.is_file_mandatory)
                                                                                                { %>
                                                                                                <span class="required">*
                                                                                                    (Zorunlu)</span>
                                                                                                <% } else { %>
                                                                                                    <span
                                                                                                        style="font-size:12px; color:var(--gray-400); font-weight:400;">(İsteğe
                                                                                                        bağlı)</span>
                                                                                                    <% } %>
                                                                                                        <span
                                                                                                            style="float: right; color: var(--red); font-weight: 700;">Max:
                                                                                                            <%= task.max_file_count
                                                                                                                || 1 %>
                                                                                                                Dosya</span>
                                                                                        </label>

                                                                                        <% if (task.files &&
                                                                                            task.files.length> 0) { %>
                                                                                            <div class="existing-files"
                                                                                                style="margin-bottom: 15px;">
                                                                                                <p
                                                                                                    style="font-size: 12px; color: var(--gray-600); margin-bottom: 8px; font-weight: 600;">
                                                                                                    Yüklü Dosyalar:</p>
                                                                                                <div
                                                                                                    style="display: flex; flex-wrap: wrap; gap: 10px;">
                                                                                                    <%
                                                                                                        task.files.forEach(file=>
                                                                                                        { %>
                                                                                                        <div
                                                                                                            style="background: #f0f7ff; border: 1px solid #cce3ff; padding: 6px 12px; border-radius: 8px; font-size: 13px; display: flex; align-items: center; gap: 8px;">
                                                                                                            <i class="fas fa-file-alt"
                                                                                                                style="color: #2563eb;"></i>
                                                                                                            <a href="/uploads/responses/<%= file.file_path %>"
                                                                                                                target="_blank"
                                                                                                                style="text-decoration: none; color: #1e3a8a; font-weight: 600;">
                                                                                                                <%= file.original_name
                                                                                                                    || 'Dosya'
                                                                                                                    %>
                                                                                                            </a>
                                                                                                        </div>
                                                                                                        <% }) %>
                                                                                                </div>
                                                                                                <p
                                                                                                    style="font-size: 11px; color: #ef4444; margin-top: 8px;">
                                                                                                    <i
                                                                                                        class="fas fa-info-circle"></i>
                                                                                                    Yeni dosya
                                                                                                    yüklerseniz mevcut
                                                                                                    dosyaların tamamı
                                                                                                    değiştirilecektir.
                                                                                                </p>
                                                                                            </div>
                                                                                            <% } %>

                                                                                                <label
                                                                                                    class="file-upload-area"
                                                                                                    for="response_file_input">
                                                                                                    <i
                                                                                                        class="fas fa-cloud-upload-alt"></i>
                                                                                                    <p>Dosyaları buraya
                                                                                                        sürükleyin veya
                                                                                                        tıklayın</p>
                                                                                                    <p
                                                                                                        style="font-size:12px; color:var(--gray-400); margin-top:6px;">
                                                                                                        Birden fazla
                                                                                                        dosya
                                                                                                        seçebilirsiniz
                                                                                                        (Maksimum <%=
                                                                                                            task.max_file_count
                                                                                                            || 1 %>)</p>
                                                                                                </label>
                                                                                                <input type="file"
                                                                                                    id="response_file_input"
                                                                                                    name="response_files"
                                                                                                    multiple
                                                                                                    style="display:none;"
                                                                                                    onchange="updateFileNames(this)"
                                                                                                    <%=(task.is_file_mandatory
                                                                                                    && (!task.files ||
                                                                                                    task.files.length===0))
                                                                                                    ? 'required' : ''
                                                                                                    %>>
                                                                                                <div id="selected-files-list"
                                                                                                    style="margin-top:8px; display:none;">
                                                                                                    <div
                                                                                                        style="font-size: 12px; font-weight: 700; color: #1e3a5a; margin-bottom: 5px;">
                                                                                                        Seçilen Yeni
                                                                                                        Dosyalar:</div>
                                                                                                    <div id="file-items-container"
                                                                                                        style="display: flex; flex-direction: column; gap: 5px;">
                                                                                                    </div>
                                                                                                </div>
                                                                                    </div>
                                                                                    <% } %>

                                                                                        <script>
                                                                                            function updateFileNames(input) {
                                                                                                const listDiv = document.getElementById('selected-files-list');
                                                                                                const container = document.getElementById('file-items-container');
                                                                                                const maxFiles = <%= task.max_file_count || 1 %>;

                                                                                                container.innerHTML = '';

                                                                                                if (input.files && input.files.length > 0) {
                                                                                                    if (input.files.length > maxFiles) {
                                                                                                        alert(`En fazla ${maxFiles} dosya yükleyebilirsiniz. Şu an ${input.files.length} dosya seçtiniz.`);
                                                                                                        input.value = '';
                                                                                                        listDiv.style.display = 'none';
                                                                                                        return;
                                                                                                    }

                                                                                                    listDiv.style.display = 'block';
                                                                                                    Array.from(input.files).forEach(file => {
                                                                                                        const item = document.createElement('div');
                                                                                                        item.style.cssText = 'padding: 8px 12px; background: white; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 13px; color: #334155; display: flex; align-items: center; gap: 8px;';
                                                                                                        item.innerHTML = `<i class="fas fa-file-check" style="color: #10b981;"></i> ${file.name} (${(file.size / 1024).toFixed(1)} KB)`;
                                                                                                        container.appendChild(item);
                                                                                                    });
                                                                                                } else {
                                                                                                    listDiv.style.display = 'none';
                                                                                                }
                                                                                            }
                                                                                        </script>

                                                                                        <div class="form-actions">
                                                                                            <button type="submit"
                                                                                                name="status"
                                                                                                value="in_progress"
                                                                                                class="btn-save">
                                                                                                <i
                                                                                                    class="fas fa-save"></i>
                                                                                                Kaydet (Devam Ediyor)
                                                                                            </button>
                                                                                            <button type="submit"
                                                                                                name="status"
                                                                                                value="completed"
                                                                                                class="btn-submit">
                                                                                                <i
                                                                                                    class="fas fa-check-circle"></i>
                                                                                                Tamamlandı Olarak Gönder
                                                                                            </button>
                                                                                        </div>
                                                            </form>
                                                </div>
                                            </div>
                                            <% } else { %>
                                                <!-- Görev tamamlandı veya onaya gönderildi -->
                                                <div class="section-card">
                                                    <div class="section-header">
                                                        <i class="fas fa-lock"></i>
                                                        <%= task.status==='pending_approval' ? 'Onay Bekleyen Yanıt'
                                                            : 'Tamamlanan Yanıt' %>
                                                    </div>
                                                    <div class="section-body">
                                                        <% if (task.status==='pending_approval' ) { %>
                                                            <div class="alert alert-warning"
                                                                style="margin-bottom: 24px;">
                                                                <i class="fas fa-info-circle"></i>
                                                                <strong>Bilgi:</strong> Yanıtınız yönetici onayına
                                                                sunulmuştur. Değişiklik yapmak isterseniz lütfen mesaj
                                                                kısmından yöneticiye ulaşarak iade isteyiniz.
                                                            </div>
                                                            <% } %>

                                                                <% if (task.response_note) { %>
                                                                    <div class="response-display"
                                                                        style="margin-bottom:16px;">
                                                                        <p><strong>Notunuz:</strong></p>
                                                                        <p
                                                                            style="margin:0; font-size:14px; color:var(--gray-800);">
                                                                            <%= task.response_note %>
                                                                        </p>
                                                                    </div>
                                                                    <% } %>
                                                                        <% if (task.response_file) { %>
                                                                            <div class="response-display">
                                                                                <p><strong><i
                                                                                            class="fas fa-paperclip"></i>
                                                                                        Yüklediğiniz Dosya:</strong></p>
                                                                                <a href="/uploads/responses/<%= task.response_file %>"
                                                                                    target="_blank">
                                                                                    <i class="fas fa-file"></i> Dosyayı
                                                                                    Görüntüle
                                                                                </a>
                                                                            </div>
                                                                            <% } %>
                                                                                <% if (taskFields && taskFields.length>
                                                                                    0) { %>
                                                                                    <div style="margin-top:20px;">
                                                                                        <strong
                                                                                            style="font-size:14px; color:var(--gray-800);">Form
                                                                                            Cevaplarınız:</strong>
                                                                                        <% taskFields.forEach(field=> {
                                                                                            %>
                                                                                            <div
                                                                                                style="margin-top:12px; padding:14px; background:var(--gray-50); border:1px solid var(--gray-200); border-radius:10px;">
                                                                                                <div
                                                                                                    style="font-weight:600; font-size:13px; color:var(--gray-600); margin-bottom:4px;">
                                                                                                    <%= field.field_label
                                                                                                        %>
                                                                                                </div>
                                                                                                <div
                                                                                                    style="font-size:14px; color:var(--gray-800);">
                                                                                                    <%= responsesMap[field.id]
                                                                                                        || '-' %>
                                                                                                </div>
                                                                                            </div>
                                                                                            <% }) %>
                                                                                    </div>
                                                                                    <% } %>
                                                    </div>
                                                </div>
                                                <% } %>

                                                    <!-- Mesajlaşma Bölümü -->
                                                    <div class="section-card" id="messages">
                                                        <div class="section-header"><i class="fas fa-comments"></i>
                                                            Mesajlar</div>
                                                        <div class="section-body">
                                                            <div class="messages-box" id="messagesBox">
                                                                <% if (messages && messages.length> 0) { %>
                                                                    <% messages.forEach(msg=> { %>
                                                                        <% const isMe=msg.sender_id===currentUserId; %>
                                                                            <div
                                                                                class="msg-bubble <%= isMe ? 'me' : 'them' %>">
                                                                                <div class="msg-sender">
                                                                                    <%= isMe ? 'Siz' : (msg.full_name
                                                                                        || 'Yönetici' ) %>
                                                                                </div>
                                                                                <div>
                                                                                    <%= msg.message %>
                                                                                </div>
                                                                                <div class="msg-time">
                                                                                    <%= new
                                                                                        Date(msg.created_at).toLocaleString('tr-TR',
                                                                                        { day:'2-digit',
                                                                                        month:'2-digit', year:'numeric',
                                                                                        hour:'2-digit', minute:'2-digit'
                                                                                        }) %>
                                                                                </div>
                                                                            </div>
                                                                            <% }) %>
                                                                                <% } else { %>
                                                                                    <div
                                                                                        style="text-align:center; color:var(--gray-400); padding:40px 20px;">
                                                                                        <i class="fas fa-comment-slash"
                                                                                            style="font-size:32px; margin-bottom:10px; display:block;"></i>
                                                                                        Henüz mesaj yok.
                                                                                    </div>
                                                                                    <% } %>
                                                            </div>

                                                            <form action="/okul/tasks/<%= task.id %>/message"
                                                                method="POST" class="msg-input-row">
                                                                <input type="hidden" name="_csrf"
                                                                    value="<%= csrfToken %>">
                                                                <input type="text" name="message" class="msg-input"
                                                                    placeholder="Bir mesaj yazın..." required>
                                                                <button type="submit" class="btn-send"><i
                                                                        class="fas fa-paper-plane"></i></button>
                                                            </form>
                                                        </div>
                                                    </div>

    <script src="/js/okul_task_detail.js"></script>
                                                    <%- include('../layouts/school_footer') %>