<%- include('../layouts/header') %>

    <link rel="stylesheet" href="/css/admin_dashboard.css">

    <div class="db">

        <script src="/js/chart.min.js"></script>

        <!-- HEADER -->
        <div class="db-header">
            <div class="db-header-left">
                <div class="db-header-icon"><i class="fas fa-chart-line"></i></div>
                <div>
                    <h1>İlçe Milli Eğitim Kontrol Paneli</h1>
                    <p>Tüm okulların görev takibi ve durum merkezi</p>
                </div>
            </div>
            <div class="db-date">
                <i class="far fa-calendar-alt"></i>
                <span id="dateDisplay"></span>
            </div>
        </div>

        <script>
            document.getElementById('dateDisplay').innerText = new Date().toLocaleDateString('tr-TR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        </script>

        <!-- İSTATİSTİK KARTLARI -->
        <div class="stat-row">
            <div class="s-card">
                <div class="s-icon"><i class="fas fa-school"></i></div>
                <div class="s-text">
                    <h3>
                        <%= totalUsers %>
                    </h3>
                    <p>Kurum</p>
                </div>
            </div>
            <div class="s-card">
                <div class="s-icon"><i class="fas fa-tasks"></i></div>
                <div class="s-text">
                    <h3>
                        <%= totalTasks %>
                    </h3>
                    <p>Aktif Görev</p>
                </div>
            </div>
            <div class="s-card">
                <div class="s-icon"><i class="fas fa-clock"></i></div>
                <div class="s-text">
                    <h3>
                        <%= pendingTasks || 0 %>
                    </h3>
                    <p>Bekleyen</p>
                </div>
            </div>
            <div class="s-card">
                <div class="s-icon"><i class="fas fa-check-circle"></i></div>
                <div class="s-text">
                    <h3>%<%= successRate %>
                    </h3>
                    <p>Başarı</p>
                </div>
            </div>
        </div>

        <!-- GRAFİK SATIRI -->
        <div class="chart-row">
            <div class="c-card">
                <div class="c-head">
                    <span>Kurum Türü Başarısı (%)</span>
                    <div class="c-head-icon bar"><i class="fas fa-chart-bar"></i></div>
                </div>
                <div class="chart-box">
                    <canvas id="schoolTypeChart" data-chart='<%- JSON.stringify(chartData.schoolTypes) %>'></canvas>
                </div>
            </div>

            <div class="c-card">
                <div class="c-head">
                    <span>Görev Durumları</span>
                    <div class="c-head-icon pie"><i class="fas fa-chart-pie"></i></div>
                </div>
                <div class="chart-box" style="display: flex; justify-content: center; align-items: center;">
                    <canvas id="statusChart" data-chart='<%- JSON.stringify(chartData.statusDist) %>'></canvas>
                </div>
            </div>

            <div class="c-card">
                <div class="c-head">
                    <span>En Başarılı 5 Kurum</span>
                    <div class="c-head-icon trophy"><i class="fas fa-trophy"></i></div>
                </div>
                <ul class="top-list">
                    <% if (chartData && chartData.topSchools.length> 0) { %>
                        <% chartData.topSchools.forEach((school, index)=> { %>
                            <li class="top-item">
                                <div class="top-rank">
                                    <%= index + 1 %>
                                </div>
                                <div class="top-name">
                                    <%= school.school_name %>
                                </div>
                                <div class="top-badge">
                                    <%= school.completed_count %> Görev
                                </div>
                            </li>
                            <% }); %>
                                <% } else { %>
                                    <li class="item-empty"><i class="fas fa-trophy"></i> Henüz veri yok</li>
                                    <% } %>
                </ul>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                if (typeof Chart === 'undefined') return;

                const canvas1 = document.getElementById('schoolTypeChart');
                const canvas2 = document.getElementById('statusChart');
                const schoolTypeData = JSON.parse(canvas1.getAttribute('data-chart'));
                const statusData = JSON.parse(canvas2.getAttribute('data-chart'));

                if (canvas1) {
                    new Chart(canvas1.getContext('2d'), {
                        type: 'bar',
                        data: {
                            labels: schoolTypeData.labels,
                            datasets: [{
                                label: 'Tamamlanma (%)',
                                data: schoolTypeData.data,
                                backgroundColor: ['#E31E24', '#3b82f6', '#10b981', '#f59e0b', '#8b5cf6', '#06b6d4', '#ec4899', '#64748b', '#f97316'],
                                borderRadius: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { beginAtZero: true, max: 100, grid: { color: '#f1f5f9' }, ticks: { font: { size: 10 } } },
                                x: { grid: { display: false }, ticks: { font: { size: 9 } } }
                            }
                        }
                    });
                }

                if (canvas2) {
                    new Chart(canvas2.getContext('2d'), {
                        type: 'doughnut',
                        data: {
                            labels: statusData.labels,
                            datasets: [{
                                data: statusData.counts,
                                backgroundColor: ['#fbbf24', '#3b82f6', '#10b981', '#ef4444'],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            cutout: '65%',
                            plugins: {
                                legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 10, weight: '600' }, padding: 12 } }
                            }
                        }
                    });
                }
            });
        </script>

        <!-- ANA İÇERİK: Duyurular + Dosyalar | Takvim | Görev Durumu -->
        <div class="main-row">

            <!-- SOL: Duyurular + Dosyalar -->
            <div>
                <div class="panel" style="margin-bottom: 14px;">
                    <div class="panel-head">
                        <div class="panel-head-icon red"><i class="fas fa-bullhorn"></i></div>
                        <span>Kurumsal Duyurular</span>
                    </div>

                    <form action="/admin/announcements" method="POST" class="ann-form" style="display: block;">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        
                        <div style="display: flex; gap: 10px;">
                            <input type="text" name="title" class="ann-input" placeholder="Okullara hızlı duyuru yayınla (Başlık)..."
                                required autocomplete="off" id="ann-title">
                            <button type="submit" class="ann-send"><i class="fas fa-paper-plane"></i></button>
                        </div>
                        
                        <div id="ann-content-wrapper" style="display: none; margin-top: 10px;">
                            <textarea name="content" class="ann-input" placeholder="Duyuru detaylarını buraya yazabilirsiniz..."
                                rows="3" style="width: 100%; box-sizing: border-box; resize: vertical; margin: 0;"></textarea>
                        </div>
                    </form>

                    <script>
                        const annTitle = document.getElementById('ann-title');
                        const annWrapper = document.getElementById('ann-content-wrapper');
                        
                        annTitle.addEventListener('focus', () => {
                            annWrapper.style.display = 'block';
                        });
                        
                        document.addEventListener('click', (e) => {
                            if (!e.target.closest('.ann-form') && annWrapper.querySelector('textarea').value.trim() === '') {
                                annWrapper.style.display = 'none';
                            }
                        });
                    </script>

                    <ul class="item-list">
                        <% if(announcements.length===0) { %>
                            <li class="item-empty"><i class="fas fa-bell-slash"></i> Aktif duyuru yok.</li>
                            <% } else { %>
                                <% announcements.forEach(ann=> { %>
                                    <li class="item-row">
                                        <div class="item-icon bell"><i class="fas fa-bell"></i></div>
                                        <div class="item-content">
                                            <h4 title="<%= ann.content %>" style="cursor: help; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 250px;">
                                                <%= ann.title %>
                                            </h4>
                                            <p><i class="far fa-clock" style="font-size:9px;"></i>
                                                <%= ann.created_at ? new Date(ann.created_at).toLocaleDateString('tr-TR') : '' %>
                                                <% if(ann.content && ann.content !== 'Detaylar için panele bakınız.') { %>
                                                    <span style="margin-left:5px; color:#E31E24; font-size:9px;" title="<%= ann.content %>"><i class="fas fa-info-circle"></i> Detay var</span>
                                                <% } %>
                                            </p>
                                        </div>
                                        <form action="/admin/announcements/<%= ann.id %>/delete" method="POST"
                                            style="display:inline;">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="item-del"
                                                onclick="return confirm('Bu duyuruyu silmek istediğinize emin misiniz?')"
                                                title="Sil">
                                                <i class="fas fa-trash-alt" style="font-size:11px;"></i>
                                            </button>
                                        </form>
                                    </li>
                                    <% }) %>
                                        <% } %>
                    </ul>
                </div>

                <div class="panel">
                    <div class="panel-head">
                        <div class="panel-head-icon amber"><i class="fas fa-folder-open"></i></div>
                        <span>Sabit Dosyalar</span>
                    </div>
                    <div style="padding: 6px;">
                        <% if(systemFiles.length===0) { %>
                            <div class="item-empty"><i class="fas fa-folder-open"></i> Dosya eklenmemiş.</div>
                            <% } else { %>
                                <% systemFiles.forEach(file=> { %>
                                    <a href="/uploads/system/<%= file.file_path %>" target="_blank" class="file-link">
                                        <div class="item-icon file"><i class="fas fa-file-alt"></i></div>
                                        <span>
                                            <%= file.title %>
                                        </span>
                                        <i class="fas fa-download"></i>
                                    </a>
                                    <% }) %>
                                        <% } %>
                    </div>
                </div>
            </div>


            <!-- SAĞ: Takvim + Görev Durumu -->
            <div>
                <!-- Takvim -->
                <div class="cal-panel" style="margin-bottom: 14px;">
                    <div class="cal-top">
                        <div class="cal-top-left">
                            <div class="cal-top-icon"><i class="fas fa-calendar-alt"></i></div>
                            <span class="cal-month-label" id="calMonthYear"></span>
                        </div>
                        <div class="cal-nav">
                            <button class="cal-nav-btn" onclick="changeMonth(-1)"><i
                                    class="fas fa-chevron-left"></i></button>
                            <button class="cal-nav-btn today" onclick="goToToday()">Bugün</button>
                            <button class="cal-nav-btn" onclick="changeMonth(1)"><i
                                    class="fas fa-chevron-right"></i></button>
                        </div>
                    </div>
                    <div class="cal-grid" id="adminCalendar" data-events='<%- calendarEvents %>'></div>
                    <div class="upcoming-section">
                        <div class="upcoming-label"><i class="fas fa-clock" style="font-size:10px;"></i> Yaklaşan Teslim
                            Tarihleri</div>
                        <div id="upcomingList"></div>
                    </div>
                </div>

                <!-- Görev Tamamlanma -->
                <div class="status-panel">
                    <div class="status-head">
                        <div class="status-head-icon"><i class="fas fa-chart-pie"></i></div>
                        <span>Görev Tamamlanma Durumu</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 24px; padding: 8px 0;">
                        <div class="donut-chart" style="flex-shrink: 0;">
                            <svg viewBox="0 0 42 42">
                                <circle cx="21" cy="21" r="15.9" fill="transparent" stroke="#f1f5f9" stroke-width="4" />
                                <circle cx="21" cy="21" r="15.9" fill="transparent" stroke="#10b981" stroke-width="4"
                                    stroke-dasharray="<%= totalAssignments > 0 ? (completedTasks/totalAssignments)*100 : 0 %> <%= totalAssignments > 0 ? 100 - (completedTasks/totalAssignments)*100 : 100 %>"
                                    stroke-linecap="round" />
                            </svg>
                            <div class="center-text">
                                <div class="big">%<%= successRate %>
                                </div>
                                <div class="small">Başarı</div>
                            </div>
                        </div>
                        <div style="flex: 1;">
                            <div class="stat-item">
                                <div class="stat-dot" style="background: #10b981;"></div>
                                <span class="stat-item-label">Tamamlanan</span>
                                <span class="stat-item-value">
                                    <%= completedTasks %>
                                </span>
                            </div>
                            <div class="stat-item">
                                <div class="stat-dot" style="background: #f59e0b;"></div>
                                <span class="stat-item-label">Bekleyen / İşlemde</span>
                                <span class="stat-item-value">
                                    <%= pendingTasks %>
                                </span>
                            </div>
                            <div class="stat-item">
                                <div class="stat-dot" style="background: #3b82f6;"></div>
                                <span class="stat-item-label">Toplam Atama</span>
                                <span class="stat-item-value">
                                    <%= totalAssignments %>
                                </span>
                            </div>
                        </div>
                    </div>
                    <a href="/admin/tasks" class="stat-link">Tüm Görevleri İncele <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>

    <script>
    <script src="/js/admin_dashboard.js"></script>
    <%- include('../layouts/footer') %>