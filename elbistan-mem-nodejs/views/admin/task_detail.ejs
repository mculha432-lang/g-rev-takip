<%- include('../layouts/header') %>

  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --red: #dc2626;
      --red-dark: #b91c1c;
      --red-muted: #fef2f2;
      --red-border: #fecaca;
      --blue: #2563eb;
      --blue-muted: #eff6ff;
      --blue-border: #dbeafe;
      --green: #059669;
      --green-muted: #ecfdf5;
      --green-border: #d1fae5;
      --orange: #f97316;
      --orange-muted: #fff7ed;
      --orange-border: #ffedd5;
      --surface: #ffffff;
      --border: #e5e7eb;
      --border-light: #f3f4f6;
      --text-1: #111827;
      --text-2: #374151;
      --text-3: #6b7280;
      --text-4: #9ca3af;
      --shadow-sm: 0 1px 3px rgba(0, 0, 0, .07);
      --shadow-md: 0 4px 16px rgba(0, 0, 0, .08);
      --shadow-lg: 0 20px 50px rgba(0, 0, 0, .14);
      --r-sm: 8px;
      --r-md: 12px;
      --r-lg: 16px;
      --r-xl: 20px;
      --font: 'Plus Jakarta Sans', sans-serif;
      --mono: 'JetBrains Mono', monospace;
    }

    .tp {
      font-family: var(--font);
      color: var(--text-1);
      -webkit-font-smoothing: antialiased;
    }

    /* ── Page Header ── */
    .tp .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 18px 24px;
      margin-bottom: 20px;
      box-shadow: var(--shadow-sm);
    }

    .tp .ph-left {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .tp .ph-icon {
      width: 46px;
      height: 46px;
      background: var(--red);
      border-radius: var(--r-md);
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 18px;
      flex-shrink: 0;
    }

    .tp .page-header h1 {
      font-size: 17px;
      font-weight: 800;
      color: var(--text-1);
      margin: 0;
    }

    .tp .page-header p {
      font-size: 12px;
      color: var(--text-3);
      margin: 2px 0 0;
    }

    /* ── Buttons ── */
    .tp .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 16px;
      background: var(--border-light);
      color: var(--text-2);
      text-decoration: none;
      border-radius: var(--r-sm);
      font-size: 13px;
      font-weight: 600;
      border: 1px solid var(--border);
      cursor: pointer;
      transition: background .18s;
    }

    .tp .btn-back:hover {
      background: var(--border);
      color: var(--text-1);
    }

    .tp .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 16px;
      background: var(--red);
      color: #fff;
      text-decoration: none;
      border-radius: var(--r-sm);
      font-size: 12px;
      font-weight: 700;
      border: none;
      cursor: pointer;
      white-space: nowrap;
      transition: background .18s;
    }

    .tp .btn-primary:hover {
      background: var(--red-dark);
      color: #fff;
    }

    .tp .btn-sm {
      padding: 6px 10px;
      border-radius: var(--r-sm);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      border: 1px solid;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      transition: background .15s, color .15s;
      text-decoration: none;
      white-space: nowrap;
      font-family: var(--font);
    }

    .tp .btn-blue {
      background: var(--blue-muted);
      color: var(--blue);
      border-color: var(--blue-border);
    }

    .tp .btn-blue:hover {
      background: var(--blue);
      color: #fff;
      border-color: var(--blue);
    }

    .tp .btn-green {
      background: var(--green-muted);
      color: var(--green);
      border-color: var(--green-border);
    }

    .tp .btn-green:hover {
      background: var(--green);
      color: #fff;
      border-color: var(--green);
    }

    .tp .btn-red {
      background: var(--red-muted);
      color: var(--red);
      border-color: var(--red-border);
    }

    .tp .btn-red:hover {
      background: var(--red);
      color: #fff;
      border-color: var(--red);
    }

    /* ── Task Card ── */
    .tp .task-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 26px 28px;
      margin-bottom: 20px;
      box-shadow: var(--shadow-sm);
    }

    .tp .task-card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
    }

    .tp .task-title {
      font-size: 22px;
      font-weight: 800;
      color: var(--text-1);
      line-height: 1.25;
    }

    .tp .task-desc {
      font-size: 14px;
      line-height: 1.7;
      color: var(--text-2);
      background: #f8fafc;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 16px 18px;
      margin-bottom: 18px;
    }

    .tp .task-meta {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      padding-top: 18px;
      border-top: 1px solid var(--border-light);
    }

    .tp .task-meta-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-2);
    }

    .tp .meta-icon {
      width: 34px;
      height: 34px;
      background: var(--red-muted);
      color: var(--red);
      border-radius: var(--r-sm);
      display: grid;
      place-items: center;
      font-size: 14px;
      flex-shrink: 0;
    }

    .tp .meta-label {
      display: block;
      font-size: 10px;
      font-weight: 500;
      color: var(--text-4);
      text-transform: uppercase;
      letter-spacing: .4px;
      margin-bottom: 2px;
    }

    .tp .task-meta-item a {
      text-decoration: none;
      color: inherit;
      font-weight: 700;
    }

    .tp .task-meta-item a:hover {
      color: var(--blue);
    }

    /* ── Stats Grid ── */
    .tp .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 20px;
    }

    .tp .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 20px 22px;
      display: flex;
      align-items: center;
      gap: 16px;
      box-shadow: var(--shadow-sm);
      transition: box-shadow .2s, transform .2s;
    }

    .tp .stat-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }

    .tp .stat-icon {
      width: 52px;
      height: 52px;
      border-radius: var(--r-md);
      display: grid;
      place-items: center;
      font-size: 22px;
      flex-shrink: 0;
    }

    .tp .stat-info h3 {
      font-size: 30px;
      font-weight: 800;
      line-height: 1;
      color: var(--text-1);
      margin: 0;
    }

    .tp .stat-info p {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .5px;
      margin: 5px 0 0;
    }

    .tp .s-blue .stat-icon {
      background: var(--blue-muted);
      color: var(--blue);
    }

    .tp .s-yellow .stat-icon {
      background: #fef3c7;
      color: #d97706;
    }

    .tp .s-orange .stat-icon {
      background: var(--orange-muted);
      color: var(--orange);
    }

    .tp .s-green .stat-icon {
      background: var(--green-muted);
      color: var(--green);
    }

    /* ── Card / Table ── */
    .tp .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }

    .tp .card-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 16px 22px;
      border-bottom: 1px solid var(--border);
      background: #f8fafc;
      font-size: 14px;
      font-weight: 700;
      color: var(--text-2);
    }

    .tp .ch-icon {
      width: 30px;
      height: 30px;
      background: var(--red-muted);
      color: var(--red);
      border-radius: var(--r-sm);
      display: grid;
      place-items: center;
      font-size: 13px;
    }

    .tp .table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .tp table {
      width: 100%;
      border-collapse: collapse;
    }

    .tp thead th {
      text-align: left;
      padding: 12px 18px;
      font-size: 10.5px;
      font-weight: 700;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .5px;
      background: #f8fafc;
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }

    .tp th.sortable {
      cursor: pointer;
      user-select: none;
      transition: background .15s;
    }

    .tp th.sortable:hover {
      background: var(--border-light);
    }

    .tp th.sortable .sort-icon {
      margin-left: 4px;
      opacity: .4;
      font-size: 9px;
    }

    .tp th.sortable.active .sort-icon {
      opacity: 1;
      color: var(--red);
    }

    .tp tbody tr:nth-child(odd) td {
      background: var(--surface);
    }

    .tp tbody tr:nth-child(even) td {
      background: #fafafa;
    }

    .tp tbody tr:hover td {
      background: #f0f4ff !important;
    }

    .tp td {
      padding: 14px 18px;
      border-bottom: 1px solid var(--border-light);
      font-size: 13px;
      color: var(--text-2);
      vertical-align: middle;
    }

    .tp tbody tr:last-child td {
      border-bottom: none;
    }

    .tp .school-name {
      font-weight: 700;
      font-size: 13px;
      color: var(--text-1);
    }

    .tp .school-code {
      font-family: var(--mono);
      background: var(--border-light);
      border: 1px solid var(--border);
      padding: 4px 9px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-2);
    }

    /* ── Badges ── */
    .tp .badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 11px;
      border-radius: 20px;
      font-size: 10.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .4px;
      white-space: nowrap;
    }

    .tp .badge-pending {
      background: var(--orange-muted);
      color: #c2410c;
      border: 1px solid var(--orange-border);
    }

    .tp .badge-in_progress {
      background: var(--blue-muted);
      color: var(--blue);
      border: 1px solid var(--blue-border);
    }

    .tp .badge-completed {
      background: var(--green-muted);
      color: var(--green);
      border: 1px solid var(--green-border);
    }

    .tp .badge-rejected {
      background: var(--red-muted);
      color: var(--red);
      border: 1px solid var(--red-border);
    }

    .tp .badge-pending_approval {
      background: var(--orange-muted);
      color: #c2410c;
      border: 1px solid var(--orange-border);
    }

    .tp .badge-time {
      display: block;
      font-size: 10px;
      color: var(--text-4);
      margin-top: 3px;
    }

    /* ── Modals ── */
    .tp-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, .6);
      backdrop-filter: blur(6px);
      z-index: 9999;
      align-items: center;
      justify-content: center;
    }

    .tp-modal.active {
      display: flex;
      animation: tpFadeIn .18s ease;
    }

    @keyframes tpFadeIn {
      from {
        opacity: 0;
      }

      to {
        opacity: 1;
      }
    }

    .tp-modal-box {
      background: var(--surface);
      border-radius: var(--r-xl);
      padding: 28px;
      width: 90%;
      max-width: 480px;
      box-shadow: var(--shadow-lg);
      border-top: 4px solid var(--red);
      animation: tpSlideUp .22s cubic-bezier(.34, 1.56, .64, 1) forwards;
      transform: scale(.96) translateY(8px);
      font-family: var(--font);
    }

    @keyframes tpSlideUp {
      to {
        transform: scale(1) translateY(0);
      }
    }

    .tp-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .tp-modal-title {
      font-size: 17px;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 9px;
    }

    .tp-modal-sub {
      font-size: 13px;
      color: var(--text-2);
      margin-bottom: 16px;
    }

    .tp-modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }

    .tp-btn-close {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-4);
      font-size: 16px;
      padding: 4px 6px;
      border-radius: 6px;
      transition: color .15s;
      font-family: var(--font);
    }

    .tp-btn-close:hover {
      color: var(--text-1);
    }

    .tp-input {
      width: 100%;
      border: 1.5px solid var(--border);
      padding: 11px 13px;
      border-radius: var(--r-sm);
      font-family: var(--font);
      font-size: 13px;
      background: #f8fafc;
      color: var(--text-1);
      transition: border-color .18s;
      box-sizing: border-box;
    }

    .tp-input:focus {
      outline: none;
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, .1);
    }

    textarea.tp-input {
      min-height: 100px;
      resize: vertical;
      margin-bottom: 18px;
    }

    textarea.tp-input:focus {
      border-color: var(--red);
      box-shadow: 0 0 0 3px rgba(220, 38, 38, .1);
    }

    .tp-msg-list {
      background: #f8fafc;
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      height: 280px;
      overflow-y: auto;
      padding: 14px;
      margin-bottom: 14px;
      display: flex;
      flex-direction: column;
      gap: 9px;
    }

    .tp-msg-row {
      display: flex;
      gap: 9px;
    }

    .tp-msg-row .tp-input {
      flex: 1;
      width: auto;
    }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
      .tp .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 700px) {
      .tp .stats-grid {
        grid-template-columns: 1fr;
      }

      .tp .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }

      .tp .task-card-top {
        flex-direction: column;
      }
    }
  </style>

  <div class="tp">

    <!-- Page Header -->
    <div class="page-header">
      <div class="ph-left">
        <div class="ph-icon"><i class="fas fa-chart-bar"></i></div>
        <div>
          <h1>Görev Takibi</h1>
          <p>Görevin okul bazlı durumunu ve istatistiklerini inceleyin.</p>
        </div>
      </div>
      <a href="/admin/tasks" class="btn-back"><i class="fas fa-arrow-left"></i> Geri Dön</a>
    </div>

    <!-- Task Info Card -->
    <div class="task-card">
      <div class="task-card-top">
        <div class="task-title">
          <%= task.title %>
        </div>
        <a href="/admin/tasks/<%= task.id %>/edit" class="btn-primary">
          <i class="fas fa-edit"></i> Düzenle
        </a>
      </div>
      <% if (task.description) { %>
        <div class="task-desc">
          <%- task.description %>
        </div>
        <% } %>
          <div class="task-meta">
            <div class="task-meta-item">
              <span class="meta-icon"><i class="fas fa-calendar-alt"></i></span>
              <div>
                <span class="meta-label">Son Teslim</span>
                <%= task.deadline || 'Belirtilmemiş' %>
              </div>
            </div>
            <% if (task.file_path) { %>
              <div class="task-meta-item">
                <span class="meta-icon"><i class="fas fa-file-alt"></i></span>
                <div>
                  <span class="meta-label">Ek Dosya</span>
                  <a href="/uploads/tasks/<%= task.file_path %>" target="_blank">Dosyayı Görüntüle</a>
                </div>
              </div>
              <% } %>
          </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card s-blue">
        <div class="stat-icon"><i class="fas fa-school"></i></div>
        <div class="stat-info">
          <h3>
            <%= total %>
          </h3>
          <p>Toplam Atama</p>
        </div>
      </div>
      <div class="stat-card s-yellow">
        <div class="stat-icon"><i class="fas fa-eye"></i></div>
        <div class="stat-info">
          <h3>
            <%= readCount %>
          </h3>
          <p>Okuyan Okul</p>
        </div>
      </div>
      <div class="stat-card s-orange">
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
        <div class="stat-info">
          <h3>
            <%= pendingApprovalCount %>
          </h3>
          <p>Onay Bekleyen</p>
        </div>
      </div>
      <div class="stat-card s-green">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info">
          <h3>
            <%= completedCount %>
          </h3>
          <p>Tamamlanan</p>
        </div>
      </div>
    </div>

    <!-- Assignments Table -->
    <div class="card">
      <div class="card-header">
        <div class="ch-icon"><i class="fas fa-list-ul"></i></div>
        Okul Durumları
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th class="sortable" data-sort="name">Okul <i class="fas fa-sort sort-icon"></i></th>
              <th>Kurum Kodu</th>
              <th>Okundu</th>
              <th class="sortable" data-sort="status">Durum <i class="fas fa-sort sort-icon"></i></th>
              <th>Yanıt / Form</th>
              <th>Dosya</th>
              <th>İşlem</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <% assignments.forEach(assignment=> {
              const isCompleted = assignment.status === 'completed';
              const isPendingApp = assignment.status === 'pending_approval';
              const isRejected = assignment.status === 'rejected';
              
              // Görev süresi dolmuş mu kontrol et (eğer son teslim tarihi varsa)
              const hasDeadline = task.deadline && task.deadline.trim() !== '';
              const isOverdue = hasDeadline && new Date(task.deadline) < new Date();
              
              const needsAction = isCompleted || isPendingApp || isOverdue;
              const showRejectBtn = !isRejected && needsAction;
              %>
              <tr data-name="<%= assignment.full_name %>" data-status="<%= assignment.status %>"
                data-read="<%= assignment.is_read ? 1 : 0 %>">

                <td>
                  <div class="school-name">
                    <%= assignment.full_name %>
                  </div>
                </td>
                <td><span class="school-code">
                    <%= assignment.username %>
                  </span></td>

                <td>
                  <% if (assignment.is_read) { %>
                    <span style="color:var(--green);font-size:12px;font-weight:600;">
                      <i class="fas fa-check-double"></i> Evet
                    </span>
                    <div style="font-size:10px;color:var(--text-4);margin-top:2px;">
                      <%= assignment.read_at ? new Date(assignment.read_at).toLocaleString('tr-TR') : '' %>
                    </div>
                    <% } else { %>
                      <span style="color:var(--text-4);font-size:12px;">
                        <i class="fas fa-minus-circle"></i> Hayır
                      </span>
                      <% } %>
                </td>

                <td>
                  <% if (isCompleted) { %>
                    <span class="badge badge-completed"><i class="fas fa-check"></i> Tamamlandı</span>
                    <span class="badge-time">
                      <%= assignment.completed_at ? new Date(assignment.completed_at).toLocaleString('tr-TR') : '' %>
                    </span>
                    <% } else if (isRejected) { %>
                      <span class="badge badge-rejected"><i class="fas fa-times"></i> Reddedildi</span>
                      <% } else if (isPendingApp) { %>
                        <span class="badge badge-pending_approval">
                          <i class="fas fa-hourglass-half"></i> Onay Bekliyor
                        </span>
                        <% } else if (assignment.status==='in_progress' ) { %>
                          <span class="badge badge-in_progress">
                            <i class="fas fa-spinner fa-spin"></i> İşleniyor
                          </span>
                          <% } else { %>
                            <span class="badge badge-pending"><i class="fas fa-clock"></i> Bekliyor</span>
                            <% } %>
                </td>

                <td>
                  <% if (assignment.fieldResponses && assignment.fieldResponses.length> 0) { %>
                    <button class="btn-sm btn-red js-open-answers" data-id="<%= assignment.id %>"
                      data-name="<%= assignment.full_name %>">
                      <i class="fas fa-list"></i> Form Cevapları
                    </button>
                    <% } %>
                      <% if (assignment.response_note) { %>
                        <div style="font-style:italic;color:var(--text-3);font-size:12px;margin-top:5px;">
                          "<%= assignment.response_note %>"
                        </div>
                        <% } %>
                          <% if (!assignment.fieldResponses?.length && !assignment.response_note) { %>
                            <span style="color:var(--text-4);">—</span>
                            <% } %>
                </td>

                <td>
                  <% if (assignment.files && assignment.files.length> 0) { %>
                    <div style="display:flex;flex-direction:column;gap:4px;">
                      <% assignment.files.forEach(file=> { %>
                        <a href="/uploads/responses/<%= file.file_path %>" target="_blank" class="btn-sm btn-blue"
                          style="font-size:11px;padding:4px 8px;">
                          <i class="fas fa-file-download"></i>
                          <%= file.original_name ? (file.original_name.length> 15 ?
                            file.original_name.substring(0,12)+'...' : file.original_name)
                            : 'Dosya' %>
                        </a>
                        <% }) %>
                    </div>
                    <% } else if (assignment.response_file) { %>
                      <a href="/admin/tasks/assignments/<%= assignment.id %>/download" target="_blank"
                        class="btn-sm btn-blue">
                        <i class="fas fa-paperclip"></i> İncele
                      </a>
                      <% } else { %>
                        <span style="color:var(--text-4);">—</span>
                        <% } %>
                </td>

                <td>
                  <div style="display:flex;gap:5px;align-items:center;">
                    <button class="btn-sm btn-blue js-open-message" data-id="<%= assignment.id %>"
                      data-name="<%= assignment.full_name %>" title="Mesajlar">
                      <i class="fas fa-comment-dots"></i>
                    </button>
                    <% if (isPendingApp) { %>
                      <button class="btn-sm btn-green js-open-approve" data-id="<%= assignment.id %>"
                        data-name="<%= assignment.full_name %>" title="Onayla">
                        <i class="fas fa-check"></i>
                      </button>
                      <% } %>
                        <% if (showRejectBtn) { %>
                          <button class="btn-sm btn-red js-open-reject" data-id="<%= assignment.id %>"
                            data-name="<%= assignment.full_name %>" title="<%= isCompleted ? 'Geri Al' : 'Reddet' %>">
                            <i class="<%= isCompleted ? 'fas fa-undo' : 'fas fa-times' %>"></i>
                          </button>
                          <% } %>
                  </div>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ── REJECT MODAL ── -->
  <div id="rejectModal" class="tp-modal">
    <div class="tp-modal-box tp">
      <div class="tp-modal-header">
        <div class="tp-modal-title" style="color:var(--red);">
          <i class="fas fa-exclamation-triangle"></i> Görevi Reddet
        </div>
        <button class="tp-btn-close" data-close="rejectModal"><i class="fas fa-times"></i></button>
      </div>
      <p class="tp-modal-sub">
        <strong id="rejectSchoolName"></strong> tarafından gönderilen görevi reddetmek üzeresiniz:
      </p>
      <form id="rejectForm" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <textarea class="tp-input" name="rejection_note" placeholder="Red sebebini belirtin..." required></textarea>
        <div class="tp-modal-footer">
          <button type="button" class="btn-back" data-close="rejectModal">İptal</button>
          <button type="submit" class="btn-primary" style="padding:10px 20px;">Reddet</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── APPROVE MODAL ── -->
  <div id="approveModal" class="tp-modal">
    <div class="tp-modal-box tp" style="border-top-color:var(--green);">
      <div class="tp-modal-header">
        <div class="tp-modal-title" style="color:var(--green);">
          <i class="fas fa-check-circle"></i> Görevi Onayla
        </div>
        <button class="tp-btn-close" data-close="approveModal"><i class="fas fa-times"></i></button>
      </div>
      <p class="tp-modal-sub">
        <strong id="approveSchoolName"></strong> tarafından yapılan görevi onaylamak üzeresiniz.
      </p>
      <form id="approveForm" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="tp-modal-footer">
          <button type="button" class="btn-back" data-close="approveModal">İptal</button>
          <button type="submit" class="btn-primary" style="background:var(--green);padding:10px 20px;">Onayla</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── MESSAGE MODAL ── -->
  <div id="messageModal" class="tp-modal">
    <div class="tp-modal-box tp" style="border-top-color:var(--blue);max-width:580px;">
      <div class="tp-modal-header">
        <div class="tp-modal-title" style="color:var(--blue);">
          <i class="fas fa-comments"></i> Mesajlar
        </div>
        <button class="tp-btn-close" data-close="messageModal"><i class="fas fa-times"></i></button>
      </div>
      <p class="tp-modal-sub">
        <strong id="msgSchoolName"></strong> ile mesajlaşma geçmişi:
      </p>
      <div class="tp-msg-list" id="msgList"></div>
      <form id="messageForm" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="task_id" value="<%= task.id %>">
        <div class="tp-msg-row">
          <input type="text" name="message" class="tp-input" placeholder="Bir mesaj yazın..." required>
          <button type="submit" class="btn-primary"
            style="background:var(--blue);margin:0;padding:10px 16px;flex-shrink:0;">
            <i class="fas fa-paper-plane"></i>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── ANSWERS MODAL ── -->
  <div id="answersModal" class="tp-modal">
    <div class="tp-modal-box tp" style="max-width:580px;">
      <div class="tp-modal-header">
        <div class="tp-modal-title" style="color:var(--red);">
          <i class="fas fa-tasks"></i> Form Cevapları
        </div>
        <button class="tp-btn-close" data-close="answersModal"><i class="fas fa-times"></i></button>
      </div>
      <p class="tp-modal-sub">
        <strong id="ansSchoolName"></strong> tarafından gönderilen form cevapları:
      </p>
      <div id="ansList" style="background:#f8fafc;border:1px solid var(--border);border-radius:12px;
                    max-height:380px;overflow-y:auto;padding:14px;
                    display:flex;flex-direction:column;gap:12px;margin-bottom:18px;"></div>
      <div class="tp-modal-footer">
        <button type="button" class="btn-back" data-close="answersModal">Kapat</button>
      </div>
    </div>
  </div>

  <!-- Veriler JSON script tag'lerinde güvenli biçimde aktarılıyor -->
  <script id="messagesMapData" type="application/json"><%- JSON.stringify(messagesMap  || {}) %></script>
  <script id="assignmentsData" type="application/json"><%- JSON.stringify(assignments || []) %></script>

  <script>
    (function () {
      'use strict';

      const messagesMap = JSON.parse(document.getElementById('messagesMapData').textContent || '{}');
      const assignmentsArr = JSON.parse(document.getElementById('assignmentsData').textContent || '[]');

      const responsesMap = {};
      assignmentsArr.forEach(a => {
        if (a.fieldResponses && a.fieldResponses.length) responsesMap[a.id] = a.fieldResponses;
      });

      const ME = String('<%= typeof currentUserId !== "undefined" ? currentUserId : "" %>');
      const TASK_ID = '<%= task.id %>';

      const $ = id => document.getElementById(id);
      const show = id => { const el = $(id); if (el) el.classList.add('active'); };
      const hide = id => { const el = $(id); if (el) el.classList.remove('active'); };

      /* ── Sıralama ── */
      const sortDir = { name: 1, status: 1 };
      const statusRank = row => {
        const s = row.dataset.status;
        const r = row.dataset.read === '1';
        if (s === 'rejected') return 1;
        if ((s === 'pending' || !s) && !r) return 2;
        if ((s === 'pending' || !s) && r) return 3;
        if (s === 'in_progress') return 4;
        if (s === 'pending_approval') return 5;
        if (s === 'completed') return 6;
        return 7;
      };

      function sortRows(type, header) {
        const tbody = $('tableBody');
        const rows = [...tbody.querySelectorAll('tr')];
        document.querySelectorAll('th.sortable').forEach(th => th.classList.remove('active'));
        header.classList.add('active');
        sortDir[type] *= -1;
        const dir = sortDir[type];
        header.querySelector('.sort-icon').className =
          'fas sort-icon ' + (dir === 1 ? 'fa-sort-up' : 'fa-sort-down');
        rows.sort((a, b) =>
          type === 'name'
            ? a.dataset.name.toLocaleLowerCase('tr-TR')
              .localeCompare(b.dataset.name.toLocaleLowerCase('tr-TR'), 'tr-TR') * dir
            : (statusRank(a) - statusRank(b)) * dir
        ).forEach(r => tbody.appendChild(r));
      }

      /* ── Event delegation ── */
      document.addEventListener('click', e => {
        const el = e.target.closest('[data-close],[data-sort],button,a');
        if (!el) return;
        if (el.dataset.close) { hide(el.dataset.close); return; }
        const { id, name } = el.dataset;
        if (el.classList.contains('js-open-reject')) { openReject(id, name); return; }
        if (el.classList.contains('js-open-approve')) { openApprove(id, name); return; }
        if (el.classList.contains('js-open-message')) { openMessage(id, name); return; }
        if (el.classList.contains('js-open-answers')) { openAnswers(id, name); return; }
        if (el.dataset.sort) { sortRows(el.dataset.sort, el); return; }
      });

      window.addEventListener('click', e => {
        if (e.target.classList.contains('tp-modal')) hide(e.target.id);
      });
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
          ['rejectModal', 'approveModal', 'messageModal', 'answersModal'].forEach(hide);
        }
      });

      /* ── Modal openers ── */
      function openReject(id, name) {
        $('rejectSchoolName').textContent = name;
        $('rejectForm').action = `/admin/tasks/${TASK_ID}/assignments/${id}/reject`;
        $('rejectForm').reset();
        show('rejectModal');
        setTimeout(() => {
          const ta = $('rejectForm').querySelector('textarea');
          if (ta) ta.focus();
        }, 120);
      }

      function openApprove(id, name) {
        $('approveSchoolName').textContent = name;
        $('approveForm').action = `/admin/tasks/${TASK_ID}/assignments/${id}/approve`;
        show('approveModal');
      }

      function openMessage(id, name) {
        $('msgSchoolName').textContent = name;
        $('messageForm').action = `/admin/tasks/assignments/${id}/message`;
        $('messageForm').reset();

        const list = $('msgList');
        list.innerHTML = '';
        const msgs = messagesMap[id] || [];

        if (!msgs.length) {
          list.innerHTML = `
                <div style="text-align:center;color:var(--text-4);padding:30px;font-size:13px;">
                    <i class="fas fa-inbox" style="font-size:32px;display:block;margin-bottom:10px;opacity:.5;"></i>
                    Henüz mesaj yok.
                </div>`;
        } else {
          msgs.forEach(m => {
            const isMe = String(m.sender_id) === ME;
            const wrap = document.createElement('div');
            wrap.style.cssText = [
              'max-width:80%', 'padding:9px 13px', 'border-radius:12px',
              'font-size:13px',
              `align-self:${isMe ? 'flex-end' : 'flex-start'}`,
              `background:${isMe ? 'var(--blue-muted)' : '#fff'}`,
              `color:${isMe ? '#1e3a8a' : 'var(--text-2)'}`,
              `border:${isMe ? 'none' : '1px solid var(--border)'}`
            ].join(';');

            const sender = document.createElement('div');
            sender.style.cssText = 'font-weight:700;font-size:10px;opacity:.7;margin-bottom:2px;';
            sender.textContent = isMe ? 'Siz' : m.full_name;

            const text = document.createElement('div');
            text.textContent = m.message;

            const time = document.createElement('div');
            time.style.cssText = 'font-size:10px;opacity:.5;text-align:right;margin-top:3px;';
            time.textContent = new Date(m.created_at).toLocaleTimeString('tr-TR', {
              hour: '2-digit', minute: '2-digit'
            });

            wrap.append(sender, text, time);
            list.appendChild(wrap);
          });
          setTimeout(() => list.scrollTop = list.scrollHeight, 50);
        }
        show('messageModal');
      }

      function openAnswers(id, name) {
        $('ansSchoolName').textContent = name;
        const list = $('ansList');
        list.innerHTML = '';
        const items = responsesMap[id] || [];

        if (!items.length) {
          list.innerHTML = `
                <div style="text-align:center;color:var(--text-4);padding:30px;font-size:13px;">
                    Form cevabı bulunamadı.
                </div>`;
        } else {
          items.forEach(r => {
            const card = document.createElement('div');
            card.style.cssText = 'background:#fff;border:1px solid var(--border);border-radius:8px;padding:12px 14px;';

            const label = document.createElement('div');
            label.style.cssText = 'font-weight:700;font-size:12px;color:var(--text-1);margin-bottom:5px;';
            label.textContent = r.field_label;

            const val = document.createElement('div');
            val.style.cssText = 'font-size:13px;color:var(--text-2);';
            val.textContent = r.response_value || '—';

            card.append(label, val);
            list.appendChild(card);
          });
        }
        show('answersModal');
      }

      /* ── Default sort on load ── */
      document.addEventListener('DOMContentLoaded', () => {
        const statusTh = document.querySelector('th.sortable[data-sort="status"]');
        if (statusTh) { sortDir.status = -1; sortRows('status', statusTh); }
      });

    })();
  </script>

  <%- include('../layouts/footer') %>
