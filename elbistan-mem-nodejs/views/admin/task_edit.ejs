<%- include('../layouts/header') %>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600&display=swap"
        rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/tr.js"></script>
    <script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>

    <% const safeSchoolTypes=typeof schoolTypes !=='undefined' ? schoolTypes : []; const typeLabels={ ilkokul: 'İlkokul'
        , ortaokul: 'Ortaokul' , lise: 'Lise' , anaokulu: 'Anaokulu' , diger: 'Diğer Kurumlar' ,
        rehabilitasyon: 'Rehabilitasyon' , surucu_kursu: 'Sürücü Kursu' , kurs: 'Kurs' , yurt: 'Yurt' }; const
        typeIcons={ ilkokul: 'fa-child' , ortaokul: 'fa-book-reader' , lise: 'fa-graduation-cap' , anaokulu: 'fa-baby' ,
        diger: 'fa-building' , rehabilitasyon: 'fa-hands-helping' , surucu_kursu: 'fa-car' ,
        kurs: 'fa-chalkboard-teacher' , yurt: 'fa-bed' }; const typeColors={ ilkokul: '#3b82f6' , ortaokul: '#8b5cf6' ,
        lise: '#ef4444' , anaokulu: '#f59e0b' , diger: '#6b7280' , rehabilitasyon: '#10b981' , surucu_kursu: '#f97316' ,
        kurs: '#06b6d4' , yurt: '#ec4899' }; %>

        <link rel="stylesheet" href="/css/admin_task_edit.css">

        <div class="tp page-root">
            <div class="edit-container">
                <div class="edit-panel">

                    <!-- ── Header ── -->
                    <div class="edit-header">
                        <div class="edit-header-info">
                            <div class="edit-header-icon"><i class="fas fa-edit"></i></div>
                            <div>
                                <h1>Görevi Düzenle</h1>
                                <p>Aşağıdaki adımları takip ederek görev detaylarını güncelleyin.</p>
                            </div>
                        </div>
                        <a href="/admin/tasks/<%= task.id %>" class="btn btn-ghost btn-sm">
                            <i class="fas fa-arrow-left"></i> Geri Dön
                        </a>
                    </div>

                    <!-- ── Step Nav ── -->
                    <div class="step-nav">
                        <div class="step-item active" data-step="1">
                            <div class="step-icon">1</div> Bilgiler
                        </div>
                        <div class="step-item" data-step="2">
                            <div class="step-icon">2</div> Resmî Yazı
                        </div>
                        <div class="step-item" data-step="3">
                            <div class="step-icon">3</div> Form & Ekler
                        </div>
                        <div class="step-item" data-step="4">
                            <div class="step-icon">4</div> Okullar
                        </div>
                    </div>

                    <!-- ── Form ── -->
                    <form id="editForm" action="/admin/tasks/<%= task.id %>/update" method="POST"
                        enctype="multipart/form-data" class="step-content">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                        <!-- Step 1: Bilgiler -->
                        <div class="step-pane active" id="pane-1">
                            <div class="form-group">
                                <label class="form-label">Görev Başlığı / Konusu</label>
                                <input type="text" name="title" class="form-control" value="<%= task.title %>" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Son Teslim Tarihi</label>
                                <input type="text" name="deadline" id="deadlinePicker" class="form-control"
                                    value="<%= task.deadline %>" required>
                            </div>
                        </div>

                        <!-- Step 2: Resmî Yazı -->
                        <div class="step-pane" id="pane-2">
                            <div class="form-group">
                                <label class="form-label">Görev Açıklama Metni</label>
                                <textarea name="description" id="editor"><%= task.description %></textarea>
                            </div>
                        </div>

                        <!-- Step 3: Form & Ekler -->
                        <div class="step-pane" id="pane-3">
                            <div class="gf-section-header">
                                <h3><i class="fas fa-wpforms"
                                        style="color:var(--gf-purple); margin-right:10px;"></i>Form & Ekler</h3>
                                <p>Okulların dolduracağı alanları ve dosya ayarlarını yapılandırın.</p>
                            </div>

                            <!-- Ek Dosya - MULTIPLE destekli -->
                            <div class="gf-card">
                                <div class="gf-card-label">
                                    <i class="fas fa-paperclip"></i> Ek Dosyalar
                                    <% if (taskAttachments && taskAttachments.length> 0) { %>
                                        <span
                                            style="margin-left:8px; background:#3b82f6; color:#fff; font-size:11px; padding:2px 8px; border-radius:10px;">
                                            <%= taskAttachments.length %> dosya
                                        </span>
                                        <% } %>
                                </div>

                                <!-- Mevcut dosyaların listesi — tek tek silinebilir -->
                                <% if (taskAttachments && taskAttachments.length> 0) { %>
                                    <div style="margin-bottom:14px;">
                                        <div
                                            style="font-size:12px; font-weight:700; color:#64748b; margin-bottom:8px; text-transform:uppercase; letter-spacing:.5px;">
                                            Mevcut Dosyalar
                                        </div>
                                        <div id="existingAttachments"
                                            style="display:flex; flex-direction:column; gap:8px;">
                                            <% taskAttachments.forEach(function(attach) { %>
                                                <div class="existing-attach-item" id="attach-row-<%= attach.id %>"
                                                    style="display:flex; align-items:center; gap:10px; padding:10px 14px; background:#f0f7ff; border:1px solid #cce3ff; border-radius:10px;">
                                                    <i class="fas fa-file-alt"
                                                        style="color:#2563eb; flex-shrink:0;"></i>
                                                    <span
                                                        style="flex:1; font-size:13px; font-weight:600; color:#1e3a8a; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                                        <%= attach.original_name || attach.file_path %>
                                                    </span>
                                                    <% if (attach.file_size) { %>
                                                        <span style="font-size:11px; color:#64748b; flex-shrink:0;">
                                                            (<%= (attach.file_size / 1024).toFixed(1) %> KB)
                                                        </span>
                                                        <% } %>
                                                            <a href="/uploads/tasks/<%= attach.file_path %>"
                                                                target="_blank"
                                                                style="flex-shrink:0; font-size:11px; color:#2563eb; text-decoration:none; border:1px solid #93c5fd; padding:3px 8px; border-radius:6px;"
                                                                title="Görüntüle">
                                                                <i class="fas fa-eye"></i>
                                                            </a>
                                                            <!-- Silme butonu: form içinde hidden input ile gönder -->
                                                            <button type="button"
                                                                onclick="markAttachmentForDelete('<%= attach.id %>')"
                                                                style="flex-shrink:0; background:#fef2f2; color:#ef4444; border:1px solid #fecaca; border-radius:6px; padding:4px 8px; font-size:11px; cursor:pointer;"
                                                                title="Bu dosyayı sil">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </button>
                                                            <!-- Silme için hidden input (JS tarafından dinamik ekleniyor) -->
                                                </div>
                                                <% }) %>
                                        </div>
                                        <div id="deleteAttachContainer"></div>
                                    </div>
                                    <% } else { %>
                                        <div
                                            style="font-size:13px; color:#94a3b8; margin-bottom:10px; font-style:italic;">
                                            <i class="fas fa-info-circle"></i> Henüz ek dosya yüklenmemiş.
                                        </div>
                                        <% } %>

                                            <!-- Yeni dosya yükle -->
                                            <div class="gf-file-zone"
                                                onclick="document.getElementById('taskFileInput').click()">
                                                <!-- multiple özniteliği eklendi -->
                                                <input type="file" name="task_file" id="taskFileInput" multiple
                                                    accept="*/*">
                                                <div class="gf-file-icon"><i class="fas fa-cloud-upload-alt"></i></div>
                                                <div class="gf-file-text">
                                                    <%= (taskAttachments && taskAttachments.length> 0) ? 'Yeni
                                                        dosya(lar) eklemek için tıklayın' : 'Dosya seçmek için tıklayın'
                                                        %>
                                                </div>
                                                <div class="gf-file-sub">Birden fazla dosya seçebilirsiniz — PDF, Word,
                                                    Excel vb.</div>
                                            </div>

                                            <!-- Seçilen yeni dosyaların önizlemesi -->
                                            <div class="gf-file-chosen" id="fileChosen" style="display:none;">
                                                <div id="fileChosenList"
                                                    style="display:flex; flex-direction:column; gap:6px;"></div>
                                            </div>
                            </div>

                            <!-- Dosya Ayarları -->
                            <div class="gf-card">
                                <div class="gf-card-label"><i class="fas fa-cog"></i> Dosya Yükleme Ayarları</div>

                                <div class="gf-toggle-row">
                                    <div class="gf-toggle-label">
                                        <strong>Okullar Dosya Yüklesin</strong>
                                        <span>Okulların bu göreve dosya eklemesine izin verir</span>
                                    </div>
                                    <label class="gf-switch">
                                        <input type="checkbox" name="requires_file" value="1" id="requiresFileToggle"
                                            <%=task.requires_file ? 'checked' : '' %>>
                                        <span class="gf-slider"></span>
                                    </label>
                                </div>

                                <div class="gf-toggle-row" id="mandatoryRow"
                                    style="<%= task.requires_file ? '' : 'opacity:.4; pointer-events:none;' %>">
                                    <div class="gf-toggle-label">
                                        <strong>Dosya Yükleme Zorunlu</strong>
                                        <span>Aktifse okullar dosya yüklemeden formu gönderemez</span>
                                    </div>
                                    <label class="gf-switch">
                                        <input type="checkbox" name="is_file_mandatory" value="1"
                                            id="fileMandatoryToggle" <%=task.is_file_mandatory ? 'checked' : '' %>>
                                        <span class="gf-slider"></span>
                                    </label>
                                </div>

                                <div class="gf-stepper" id="fileCountRow"
                                    style="<%= task.requires_file ? '' : 'display:none;' %>">
                                    <label><i class="fas fa-copy" style="margin-right:6px;"></i> Maksimum Dosya
                                        Sayısı</label>
                                    <button type="button" class="gf-stepper-btn"
                                        onclick="changeFileCount(-1)">−</button>
                                    <span class="gf-stepper-val" id="fileCountDisplay">
                                        <%= task.max_file_count || 1 %>
                                    </span>
                                    <button type="button" class="gf-stepper-btn" onclick="changeFileCount(1)">+</button>
                                    <input type="hidden" name="max_file_count" id="maxFileCountInput"
                                        value="<%= task.max_file_count || 1 %>">
                                </div>
                            </div>

                            <!-- Sorular -->
                            <div class="gf-card" style="padding:24px 28px 20px;">
                                <div class="gf-card-label" style="margin-bottom:6px;"><i class="fas fa-list-ul"></i>
                                    Veri Giriş Formu</div>
                                <p style="font-size:12px; color:var(--text-3); margin:0 0 20px; font-weight:500;">
                                    Okulların dolduracağı soruları ekleyin.</p>

                                <div class="gf-question-list" id="dynamicFields">
                                    <% taskFields.forEach((field, idx)=> { %>
                                        <div class="gf-question-card active-q"
                                            data-saved-options="<%= (field.field_options || '').replace(/" /g, '&quot;'
                                            ) %>">
                                            <div class="gf-card-header">
                                                <div class="gf-card-toprow">
                                                    <span class="gf-drag-handle"><i
                                                            class="fas fa-grip-vertical"></i></span>
                                                    <div class="gf-q-number">
                                                        <%= idx + 1 %>
                                                    </div>
                                                    <input type="hidden" name="field_ids" value="<%= field.id %>">
                                                    <input type="hidden" name="field_options"
                                                        class="field-options-hidden"
                                                        value="<%= (field.field_options || '').replace(/" /g, '&quot;' )
                                                        %>">
                                                    <input type="text" name="field_labels" class="gf-question-input"
                                                        value="<%= field.field_label %>"
                                                        placeholder="Soru başlığını yazın..." required>
                                                    <select name="field_types" class="gf-type-select"
                                                        onchange="window.updateCardPreview(this.closest('.gf-question-card'))">
                                                        <option value="text" <%=field.field_type==='text' ? 'selected'
                                                            : '' %>>Kısa Yanıt</option>
                                                        <option value="textarea" <%=field.field_type==='textarea'
                                                            ? 'selected' : '' %>>Paragraf</option>
                                                        <option value="number" <%=field.field_type==='number'
                                                            ? 'selected' : '' %>>Sayı</option>
                                                        <option value="radio" <%=field.field_type==='radio' ? 'selected'
                                                            : '' %>>Çoktan Seçmeli</option>
                                                        <option value="checkbox" <%=field.field_type==='checkbox'
                                                            ? 'selected' : '' %>>Onay Kutuları</option>
                                                        <option value="select" <%=field.field_type==='select'
                                                            ? 'selected' : '' %>>Açılır Menü</option>
                                                        <option value="date" <%=field.field_type==='date' ? 'selected'
                                                            : '' %>>Tarih</option>
                                                        <option value="time" <%=field.field_type==='time' ? 'selected'
                                                            : '' %>>Saat</option>
                                                        <option value="scale" <%=field.field_type==='scale' ? 'selected'
                                                            : '' %>>Doğrusal Ölçek</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="gf-card-body"></div>
                                            <div class="gf-card-actions">
                                                <div class="gf-actions-left">
                                                    <span class="gf-required-label">Zorunlu</span>
                                                    <label class="gf-switch" style="transform:scale(.85);">
                                                        <input type="checkbox" name="field_required" value="<%= idx %>"
                                                            <%=field.is_required ? 'checked' : '' %>>
                                                        <span class="gf-slider"></span>
                                                    </label>
                                                </div>
                                                <div class="gf-actions-right">
                                                    <button type="button" class="gf-action-btn"
                                                        onclick="duplicateField(this)"><i
                                                            class="fas fa-copy"></i></button>
                                                    <div class="gf-divider"></div>
                                                    <button type="button" class="gf-action-btn delete"
                                                        onclick="removeField(this)"><i
                                                            class="fas fa-trash-alt"></i></button>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>

                                            <% if (!taskFields || taskFields.length===0) { %>
                                                <div class="gf-empty" id="emptyState">
                                                    <i class="fas fa-clipboard-list"></i>
                                                    <p>Henüz soru eklenmemiş.<br><span
                                                            style="font-size:12px; color:#bbb;">Aşağıdaki butona
                                                            tıklayarak soru oluşturun.</span></p>
                                                </div>
                                                <% } %>
                                </div>
                            </div>

                            <button type="button" class="gf-add-btn" onclick="addField()">
                                <i class="fas fa-plus-circle"></i> Yeni Soru / Veri Alanı Ekle
                            </button>
                        </div>

                        <!-- Step 4: Okullar -->
                        <div class="step-pane" id="pane-4">
                            <div style="margin-bottom:20px;">
                                <h4
                                    style="font-size:12px; font-weight:800; color:var(--text-3); text-transform:uppercase; margin-bottom:12px;">
                                    Tanımlı Okullar
                                    <span
                                        style="background:var(--green); color:#fff; padding:2px 8px; border-radius:10px; margin-left:8px;">
                                        <%= assignedIds.length %>
                                    </span>
                                </h4>
                                <div class="chip-box">
                                    <% assignedSchoolDetails.forEach(s=> { %>
                                        <div class="school-chip" id="assigned-<%= s.id %>">
                                            <span>
                                                <%= s.full_name %>
                                            </span>
                                            <input type="hidden" name="remove_school_ids" value=""
                                                id="remove-input-<%= s.id %>">
                                            <button type="button" class="chip-remove"
                                                onclick="removeAssignedSchool('<%= s.id %>')">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </div>
                                        <% }) %>
                                            <% if (assignedIds.length===0) { %>
                                                <p style="font-size:13px; color:var(--text-3); font-style:italic;">Henüz
                                                    hiç okul atanmamış.</p>
                                                <% } %>
                                </div>
                            </div>

                            <div class="school-picker">
                                <div
                                    style="padding:15px; border-bottom:1px solid var(--border); background:#fff; display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
                                    <i class="fas fa-plus-circle" style="color:var(--blue);"></i>
                                    <input type="text" id="schoolSearch" class="form-control"
                                        style="border:none; padding:5px; background:transparent; flex:1;"
                                        placeholder="Yeni okul eklemek için ara...">
                                    <button type="button" class="btn btn-sm btn-navy"
                                        onclick="toggleAllNewSchools(true)">Tümünü Seç</button>
                                    <button type="button" class="btn btn-sm btn-ghost"
                                        onclick="toggleAllNewSchools(false)">Temizle</button>
                                    <div class="type-btn-group">
                                        <% safeSchoolTypes.forEach(type=> { %>
                                            <button type="button" class="type-btn" data-type="<%= type %>"
                                                style="color:<%= typeColors[type] || '#6b7280' %>; border-color:<%= typeColors[type] || '#6b7280' %>;"
                                                onclick="toggleTypeSelection('<%= type %>', this)">
                                                <i class="fas <%= typeIcons[type] || 'fa-building' %>"></i>
                                                <%= typeLabels[type] || type %>
                                            </button>
                                            <% }) %>
                                    </div>
                                </div>

                                <div style="max-height:380px; overflow-y:auto; padding:10px;" id="schoolList">
                                    <% schools.forEach(s=> {
                                        if (!assignedIds.includes(s.id)) { %>
                                        <label class="school-item" data-name="<%= s.full_name.toLowerCase() %>"
                                            data-type="<%= s.school_type %>">
                                            <input type="checkbox" name="school_ids" value="<%= s.id %>"
                                                style="width:18px; height:18px; accent-color:var(--red);">
                                            <span style="font-size:14px; font-weight:600; flex:1;">
                                                <%= s.full_name %>
                                            </span>
                                            <span
                                                style="font-size:10px; font-weight:700; padding:3px 8px; border-radius:12px; background:<%= typeColors[s.school_type] ? typeColors[s.school_type] + '18' : '#f1f5f9' %>; color:<%= typeColors[s.school_type] || '#6b7280' %>;">
                                                <%= typeLabels[s.school_type] || s.school_type || '-' %>
                                            </span>
                                        </label>
                                        <% } }) %>
                                </div>

                                <div class="school-count-badge">
                                    <span><i class="fas fa-check-circle"
                                            style="color:var(--green); margin-right:6px;"></i>Yeni Eklenecek
                                        Okul:</span>
                                    <span class="count" id="newSchoolCount">0</span>
                                </div>
                            </div>
                        </div>
                    </form>

                    <!-- ── Footer ── -->
                    <div class="edit-footer">
                        <button type="button" id="btnPrev" class="btn btn-ghost" style="visibility:hidden;">
                            <i class="fas fa-chevron-left"></i> Geri Dön
                        </button>
                        <div>
                            <button type="button" id="btnNext" class="btn btn-red">
                                Sonraki <i class="fas fa-chevron-right" style="margin-left:10px;"></i>
                            </button>
                            <button type="button" id="btnSubmit" class="btn btn-navy"
                                style="display:none; background:var(--green);">
                                Değişiklikleri Kaydet <i class="fas fa-check-circle" style="margin-left:10px;"></i>
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <script>
            // Dosya silme işaretleme fonksiyonu
            function markAttachmentForDelete(attachId) {
                if (!confirm('Bu dosyayı silmek istediğinize emin misiniz?')) return;

                // Satırı görsel olarak kaldır
                const row = document.getElementById('attach-row-' + attachId);
                if (row) {
                    row.style.opacity = '0.4';
                    row.style.pointerEvents = 'none';
                    row.style.textDecoration = 'line-through';
                }

                // Form submit edildiğinde bu id'yi sunucuya gönder
                const container = document.getElementById('deleteAttachContainer');
                if (container) {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'delete_attachment_ids';
                    input.value = attachId;
                    container.appendChild(input);
                }
            }

            // Yeni dosya seçildiğinde önizleme göster
            document.addEventListener('DOMContentLoaded', function () {
                const taskFileInput = document.getElementById('taskFileInput');
                if (taskFileInput) {
                    taskFileInput.addEventListener('change', function () {
                        const fileChosen = document.getElementById('fileChosen');
                        const fileChosenList = document.getElementById('fileChosenList');
                        if (!fileChosen || !fileChosenList) return;

                        fileChosenList.innerHTML = '';
                        if (this.files && this.files.length > 0) {
                            fileChosen.style.display = 'block';
                            Array.from(this.files).forEach(function (file) {
                                const item = document.createElement('div');
                                item.style.cssText = 'display:flex; align-items:center; gap:8px; font-size:13px; color:#334155; padding:6px 10px; background:#f0fff4; border:1px solid #bbf7d0; border-radius:8px;';
                                item.innerHTML = '<i class="fas fa-plus-circle" style="color:#16a34a; flex-shrink:0;"></i>'
                                    + '<span style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">' + file.name + '</span>'
                                    + '<span style="color:#64748b; font-size:11px; flex-shrink:0;">(' + (file.size / 1024).toFixed(1) + ' KB)</span>';
                                fileChosenList.appendChild(item);
                            });
                        } else {
                            fileChosen.style.display = 'none';
                        }
                    });
                }
            });
        </script>

        <script src="/js/admin_task_edit.js"></script>
        <%- include('../layouts/footer') %>