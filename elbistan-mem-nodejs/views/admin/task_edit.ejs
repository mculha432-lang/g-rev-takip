<%- include('../layouts/header') %>

<!-- CSS & JS Assets -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://npmcdn.com/flatpickr/dist/l10n/tr.js"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>

<style>
    :root {
        --red: #dc2626; --red-dark: #b91c1c; --red-muted: #fef2f2; --red-border: #fecaca;
        --blue: #2563eb; --blue-muted: #eff6ff; --blue-border: #dbeafe;
        --green: #059669; --green-muted: #ecfdf5; --green-border: #d1fae5;
        --navy: #1e293b; --navy-deep: #0f172a;
        --surface: #ffffff; --bg: #f8fafc;
        --border: #e2e8f0; --border-lt: #f1f5f9;
        --text-1: #1e293b; --text-2: #475569; --text-3: #94a3b8;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.07);
        --shadow-md: 0 4px 16px rgba(0,0,0,.08);
        --shadow-lg: 0 20px 50px rgba(0,0,0,.14);
        --r-sm: 8px; --r-md: 12px; --r-lg: 16px; --r-xl: 20px;
        --font: 'Plus Jakarta Sans', sans-serif;
    }

    .tp { font-family: var(--font); color: var(--text-1); -webkit-font-smoothing: antialiased; }
    .page-root { margin-top: 20px; padding-bottom: 50px; }

    /* ── Layout ── */
    .tp .edit-container { max-width: 960px; margin: 0 auto; min-height: 80vh; }
    .tp .edit-panel {
        background: var(--surface); border-radius: var(--r-xl); border: 1px solid var(--border);
        box-shadow: var(--shadow-lg); display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── Header ── */
    .tp .edit-header { padding: 24px 36px; border-bottom: 1px solid var(--border-lt); display: flex; justify-content: space-between; align-items: center; background: #fff; }
    .tp .edit-header-info { display: flex; align-items: center; gap: 14px; }
    .tp .edit-header-icon { width: 48px; height: 48px; background: var(--navy); border-radius: 12px; display: grid; place-items: center; color: #fff; font-size: 20px; }
    .tp .edit-header h1 { font-size: 20px; font-weight: 800; margin: 0; color: var(--navy); }
    .tp .edit-header p { font-size: 13px; color: var(--text-3); margin-top: 4px; font-weight: 500; }

    /* ── Step Nav ── */
    .tp .step-nav { display: flex; background: #f8fafc; border-bottom: 1px solid var(--border); padding: 0 36px; gap: 40px; overflow-x: auto; }
    .tp .step-item {
        display: flex; align-items: center; gap: 12px; padding: 20px 0;
        font-size: 14px; font-weight: 700; color: var(--text-3); cursor: pointer;
        border-bottom: 3px solid transparent; transition: all .2s; white-space: nowrap;
    }
    .tp .step-item.active { color: var(--red); border-bottom-color: var(--red); }
    .tp .step-icon { width: 28px; height: 28px; border-radius: 8px; background: #e2e8f0; display: grid; place-items: center; font-size: 12px; font-weight: 800; }
    .tp .step-item.active .step-icon { background: var(--red); color: #fff; }

    /* ── Content ── */
    .tp .step-content { flex: 1; padding: 40px 52px; background: #fff; }
    .tp .step-pane { display: none; }
    .tp .step-pane.active { display: block; animation: fadeUp .3s ease; }

    /* ── Form Elements ── */
    .tp .form-group { margin-bottom: 28px; }
    .tp .form-label { display: block; font-size: 11px; font-weight: 800; color: var(--text-2); margin-bottom: 10px; text-transform: uppercase; letter-spacing: .8px; }
    .tp .form-control {
        width: 100%; padding: 14px 18px; border: 2px solid var(--border); border-radius: var(--r-md);
        font-family: inherit; font-size: 15px; background: #f8fafc; transition: all .2s; box-sizing: border-box;
    }
    .tp .form-control:focus { outline: none; border-color: var(--blue); background: #fff; box-shadow: 0 0 0 5px rgba(37,99,235,.07); }

    /* ── Advanced Components ── */
    .tp .chip-box { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; padding: 18px; background: var(--border-lt); border-radius: 14px; border: 1px solid var(--border); }
    .tp .school-chip { 
        display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; 
        background: #fff; border: 1.5px solid var(--green); border-radius: 10px; 
        font-size: 13px; font-weight: 700; color: var(--text-1);
    }
    .tp .chip-remove { background: var(--red-muted); color: var(--red); border: none; width: 20px; height: 20px; border-radius: 6px; cursor: pointer; display: grid; place-items: center; font-size: 10px; }

    /* ── Footer ── */
    .tp .edit-footer { padding: 28px 52px; background: #f8fafc; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }

    /* ── Buttons ── */
    .btn { display: inline-flex; align-items: center; gap: 10px; padding: 13px 28px; border-radius: var(--r-md); font-size: 14px; font-weight: 700; cursor: pointer; transition: all .2s; border: none; font-family: inherit; }
    .btn-red { background: var(--red); color: #fff; box-shadow: 0 4px 14px rgba(220,38,38,.25); }
    .btn-red:hover { background: var(--red-dark); transform: translateY(-1px); }
    .btn-navy { background: var(--navy); color: #fff; }
    .btn-navy:hover { background: var(--navy-deep); }
    .btn-ghost { background: transparent; color: var(--text-2); border: 2px solid var(--border); }
    .btn-ghost:hover { background: #f1f5f9; color: var(--text-1); }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="tp page-root">
    <div class="edit-container">
        <div class="edit-panel">
            <div class="edit-header">
                <div class="edit-header-info">
                    <div class="edit-header-icon"><i class="fas fa-edit"></i></div>
                    <div>
                        <h1>Görevi Düzenle</h1>
                        <p>Aşağıdaki adımları takip ederek görev detaylarını güncelleyin.</p>
                    </div>
                </div>
                <a href="/admin/tasks/<%= task.id %>" class="btn btn-ghost btn-sm"> <i class="fas fa-arrow-left"></i> Geri Dön</a>
            </div>

            <div class="step-nav">
                <div class="step-item active" data-step="1"><div class="step-icon">1</div> Bilgiler</div>
                <div class="step-item" data-step="2"><div class="step-icon">2</div> Resmî Yazı</div>
                <div class="step-item" data-step="3"><div class="step-icon">3</div> Form & Ekler</div>
                <div class="step-item" data-step="4"><div class="step-icon">4</div> Okullar</div>
            </div>

            <form id="editForm" action="/admin/tasks/<%= task.id %>/update" method="POST" enctype="multipart/form-data" class="step-content">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <!-- Step 1: Info -->
                <div class="step-pane active" id="pane-1">
                    <div class="form-group">
                        <label class="form-label">Görev Başlığı / Konusu</label>
                        <input type="text" name="title" class="form-control" value="<%= task.title %>" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Son Teslim Tarihi</label>
                        <input type="text" name="deadline" id="deadlinePicker" class="form-control" value="<%= task.deadline %>" required>
                    </div>
                </div>

                <!-- Step 2: Content -->
                <div class="step-pane" id="pane-2">
                    <div class="form-group">
                        <label class="form-label">Görev Açıklama Metni</label>
                        <textarea name="description" id="editor"><%= task.description %></textarea>
                    </div>
                </div>

                <!-- Step 3: Fields & File -->
                <div class="step-pane" id="pane-3">
                    <div class="card" style="padding: 24px; background: #fff; border: 2px dashed var(--border); border-radius: 16px; margin-bottom: 28px;">
                        <label class="form-label">Ek Dosyayı Değiştir (İsteğe Bağlı)</label>
                        <% if (task.file_path) { %>
                            <div style="font-size:13px; margin-bottom:12px; color:var(--blue); font-weight:600;">
                                <i class="fas fa-paperclip"></i> Mevcut Dosya: <span style="text-decoration: underline;"><%= task.file_path %></span>
                            </div>
                        <% } %>
                        <input type="file" name="task_file" class="form-control" style="background: #f8fafc;">
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; padding: 20px; background: var(--border-lt); border-radius: 14px; border: 1px solid var(--border);">
                        <label style="display: flex; align-items: center; gap: 12px; cursor: pointer;">
                            <input type="checkbox" name="requires_file" value="1" <%= task.requires_file ? 'checked' : '' %> style="width:20px;height:20px;">
                            <span style="font-size:14px; font-weight:800; color:var(--navy);">Okullar Dosya Yüklesin</span>
                        </label>
                        <label style="display: flex; align-items: center; gap: 12px; cursor: pointer;">
                            <input type="checkbox" name="is_file_mandatory" value="1" <%= task.is_file_mandatory ? 'checked' : '' %> style="width:20px;height:20px;">
                            <span style="font-size:14px; font-weight:800; color:var(--navy);">Dosya Yükleme Zorunlu</span>
                        </label>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Veri Giriş Alanları</label>
                        <div id="dynamicFields" style="display:flex; flex-direction:column; gap:14px;">
                            <% taskFields.forEach(field => { %>
                                <div class="field-item" style="display:flex; gap:14px; align-items:center; background:#f1f5f9; padding:15px; border-radius:12px; border:1px solid var(--border);">
                                    <input type="hidden" name="field_ids" value="<%= field.id %>">
                                    <select name="field_types" class="form-control" style="width:130px; font-weight:700;">
                                        <option value="text" <%= field.field_type === 'text' ? 'selected' : '' %>>Metin</option>
                                        <option value="number" <%= field.field_type === 'number' ? 'selected' : '' %>>Sayı</option>
                                        <option value="date" <%= field.field_type === 'date' ? 'selected' : '' %>>Tarih</option>
                                    </select>
                                    <input type="text" name="field_labels" class="form-control" value="<%= field.field_label %>" required>
                                    <button type="button" onclick="this.parentElement.remove()" style="background:#fee2e2; border:none; color:var(--red); cursor:pointer; width:40px; height:40px; border-radius:10px; display:grid; place-items:center;"><i class="fas fa-trash"></i></button>
                                </div>
                            <% }) %>
                        </div>
                        <button type="button" class="btn btn-ghost" style="margin-top:14px; width:100%; border-style:dashed; color:var(--blue);" onclick="addField()">
                            <i class="fas fa-plus-circle"></i> Yeni Veri Alanı Ekle
                        </button>
                    </div>
                </div>

                <!-- Step 4: Schools -->
                <div class="step-pane" id="pane-4">
                    <div style="margin-bottom:20px;">
                        <h4 style="font-size:12px; font-weight:800; color:var(--text-3); text-transform:uppercase; margin-bottom:12px;">Tanımlı Okullar <span style="background:var(--green); color:#fff; padding:2px 8px; border-radius:10px; margin-left:8px;"><%= assignedIds.length %></span></h4>
                        <div class="chip-box">
                            <% assignedSchoolDetails.forEach(s => { %>
                                <div class="school-chip" id="assigned-<%= s.id %>">
                                    <span><%= s.full_name %></span>
                                    <input type="hidden" name="remove_school_ids" value="" id="remove-input-<%= s.id %>">
                                    <button type="button" class="chip-remove" onclick="removeAssignedSchool('<%= s.id %>')"><i class="fas fa-times"></i></button>
                                </div>
                            <% }) %>
                            <% if (assignedIds.length === 0) { %><p style="font-size:13px; color:var(--text-3); font-style:italic;">Henüz hiç okul atanmamış.</p><% } %>
                        </div>
                    </div>

                    <div class="school-picker" style="border: 2px solid var(--border); border-radius: 12px; overflow: hidden; background: #f8fafc;">
                        <div style="padding:15px; border-bottom:1px solid var(--border); background:#fff; display:flex; gap:12px; align-items:center;">
                            <i class="fas fa-plus-circle" style="color:var(--blue);"></i>
                            <input type="text" id="schoolSearch" class="form-control" style="border:none; padding:5px; background:transparent;" placeholder="Yeni okul eklemek için ara...">
                        </div>
                        <div style="max-height: 300px; overflow-y: auto; padding: 10px;" id="schoolList">
                            <% schools.forEach(s => { 
                                if (!assignedIds.includes(s.id)) {
                            %>
                                <label style="display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-radius: 8px; cursor: pointer; border: 1px solid transparent;" class="school-item" data-name="<%= s.full_name.toLowerCase() %>">
                                    <input type="checkbox" name="school_ids" value="<%= s.id %>" style="width:18px;height:18px;">
                                    <span style="font-size:14px; font-weight:600;"><%= s.full_name %></span>
                                </label>
                            <% }}) %>
                        </div>
                    </div>
                </div>
            </form>

            <div class="edit-footer">
                <button type="button" id="btnPrev" class="btn btn-ghost" style="visibility:hidden"><i class="fas fa-chevron-left"></i> Geri Dön</button>
                <div>
                    <button type="button" id="btnNext" class="btn btn-red">Sonraki <i class="fas fa-chevron-right" style="margin-left:10px;"></i></button>
                    <button type="button" id="btnSubmit" class="btn btn-navy" style="display:none; background:var(--green); border-color:var(--green);">Değişiklikleri Kaydet <i class="fas fa-check-circle" style="margin-left:10px;"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    let currentStep = 1;

    const gotoStep = (n) => {
        currentStep = n;
        document.querySelectorAll('.step-pane').forEach((p, i) => p.classList.toggle('active', (i+1) === n));
        document.querySelectorAll('.step-item').forEach((it, i) => it.classList.toggle('active', (i+1) === n));
        
        const btnPrev = document.getElementById('btnPrev');
        const btnNext = document.getElementById('btnNext');
        const btnSubmit = document.getElementById('btnSubmit');

        btnPrev.style.visibility = n === 1 ? 'hidden' : 'visible';
        btnNext.style.display    = n === 4 ? 'none' : 'inline-flex';
        btnSubmit.style.display  = n === 4 ? 'inline-flex' : 'none';
        
        window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    document.getElementById('btnNext').onclick = () => { if(currentStep < 4) gotoStep(currentStep + 1); };
    document.getElementById('btnPrev').onclick = () => { if(currentStep > 1) gotoStep(currentStep - 1); };
    document.getElementById('btnSubmit').onclick = () => document.getElementById('editForm').submit();

    // Editor
    ClassicEditor.create(document.querySelector('#editor'), { language: 'tr' }).catch(err => console.error(err));

    // Date Picker
    flatpickr("#deadlinePicker", { enableTime: true, dateFormat: "Y-m-d H:i", locale: "tr", time_24hr: true });

    // Dynamic Fields
    window.addField = () => {
        const container = document.getElementById('dynamicFields');
        const div = document.createElement('div');
        div.className = 'field-item';
        div.style.cssText = 'display:flex; gap:14px; align-items:center; background:#f1f5f9; padding:15px; border-radius:12px; animation:fadeUp 0.35s ease; border:1px solid var(--border);';
        div.innerHTML = `
            <input type="hidden" name="field_ids" value="">
            <select name="field_types" class="form-control" style="width:130px; font-weight:700;">
                <option value="text">Metin</option>
                <option value="number">Sayı</option>
                <option value="date">Tarih</option>
            </select>
            <input type="text" name="field_labels" class="form-control" placeholder="Veri alanı başlığı..." required>
            <button type="button" onclick="this.parentElement.remove()" style="background:#fee2e2; border:none; color:var(--red); cursor:pointer; width:40px; height:40px; border-radius:10px; display:grid; place-items:center;"><i class="fas fa-trash"></i></button>
        `;
        container.appendChild(div);
    };

    // Remove Assigned
    window.removeAssignedSchool = (id) => {
        const chip = document.getElementById('assigned-' + id);
        const input = document.getElementById('remove-input-' + id);
        if (chip && input) {
            chip.style.opacity = '0.4';
            chip.style.backgroundColor = '#fee2e2';
            input.value = id;
            chip.querySelector('button').innerHTML = '<i class="fas fa-undo"></i>';
            chip.querySelector('button').onclick = () => undoRemove(id);
        }
    };

    window.undoRemove = (id) => {
        const chip = document.getElementById('assigned-' + id);
        const input = document.getElementById('remove-input-' + id);
        if (chip && input) {
            chip.style.opacity = '1';
            chip.style.backgroundColor = '#fff';
            input.value = '';
            chip.querySelector('button').innerHTML = '<i class="fas fa-times"></i>';
            chip.querySelector('button').onclick = () => removeAssignedSchool(id);
        }
    };

    // Search
    document.getElementById('schoolSearch').oninput = (e) => {
        const term = e.target.value.toLowerCase();
        document.querySelectorAll('.school-item').forEach(item => {
            item.style.display = item.dataset.name.includes(term) ? 'flex' : 'none';
        });
    };

})();
</script>

<%- include('../layouts/footer') %>
