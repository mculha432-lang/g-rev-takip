<%- include('../layouts/header') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>

<%
  const isEdit      = typeof task !== 'undefined' && task !== null;
  const formAction  = isEdit ? `/admin/tasks/${task.id}/update` : '/admin/tasks';
  const safeTasks   = typeof tasks !== 'undefined' ? tasks : [];
  const totalTasks  = safeTasks.length;
  const activeTasks = safeTasks.filter(t => new Date(t.deadline) >= new Date()).length;
  const expiredTasks = totalTasks - activeTasks;
  const safeAssignedIds = typeof assignedIds !== 'undefined' ? assignedIds : [];
%>

<style>
:root {
  --red: #dc2626; --red-dark: #b91c1c; --red-lt: #fef2f2;
  --navy: #1e293b; --navy-deep: #0f172a;
  --surface: #ffffff; --border: #e2e8f0; --border-lt: #f1f5f9;
  --text-1: #1e293b; --text-2: #475569; --text-3: #94a3b8;
  --green: #059669; --green-lt: #f0fdf4;
  --r-md: 10px; --r-lg: 14px; --r-xl: 18px; --r-2xl: 22px;
  --font: 'Plus Jakarta Sans', sans-serif;
  --sidebar-w: 420px;
}
.page-root { margin-top: 18px; font-family: var(--font); }

#dashboardView { animation: fadeUp .32s ease; }
.dash-topbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:22px; flex-wrap:wrap; gap:12px; }
.dash-topbar-left { display:flex; align-items:center; gap:12px; }
.dash-topbar-icon { width:46px; height:46px; background:linear-gradient(135deg,var(--navy),var(--navy-deep)); border-radius:var(--r-md); display:grid; place-items:center; color:#fff; font-size:18px; box-shadow:0 5px 14px rgba(15,23,42,.22); }
.dash-topbar h1 { font-size:20px; font-weight:800; color:var(--text-1); margin:0; }
.dash-topbar p  { font-size:12px; color:var(--text-2); margin-top:2px; }

.dash-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:24px; }
.stat-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--r-lg); padding:18px 20px; display:flex; align-items:center; gap:14px; box-shadow:0 2px 10px rgba(0,0,0,.04); transition:all .2s; }
.stat-card:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,.08); }
.stat-icon { width:44px; height:44px; border-radius:var(--r-md); display:grid; place-items:center; font-size:18px; flex-shrink:0; }
.stat-icon.navy  { background:#e8edf4;        color:var(--navy);  }
.stat-icon.green { background:var(--green-lt); color:var(--green); }
.stat-icon.red   { background:var(--red-lt);   color:var(--red);   }
.stat-num   { font-size:26px; font-weight:800; color:var(--text-1); line-height:1; }
.stat-label { font-size:11px; color:var(--text-2); margin-top:3px; font-weight:600; }

.task-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:16px; }
.task-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--r-xl); overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.05); transition:all .2s; display:flex; flex-direction:column; }
.task-card:hover { transform:translateY(-3px); box-shadow:0 8px 28px rgba(0,0,0,.1); }
.card-top { padding:18px 20px 14px; flex:1; }
.card-status-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; }
.card-badge { font-size:10px; font-weight:700; padding:3px 9px; border-radius:20px; text-transform:uppercase; letter-spacing:.4px; }
.card-badge.active  { background:#dcfce7; color:#166534; }
.card-badge.expired { background:#fee2e2; color:#991b1b; }
.card-deadline { font-size:11px; color:var(--text-3); font-weight:600; display:flex; align-items:center; gap:4px; }
.card-title { font-size:14px; font-weight:700; color:var(--text-1); line-height:1.5; margin-bottom:14px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.progress-label    { display:flex; justify-content:space-between; font-size:11px; font-weight:600; color:var(--text-2); margin-bottom:6px; }
.progress-bar-wrap { height:6px; background:#f1f5f9; border-radius:3px; overflow:hidden; }
.progress-bar-fill { height:100%; border-radius:3px; background:linear-gradient(90deg,var(--green),#34d399); transition:width .6s ease; }
.card-footer { padding:12px 16px; display:flex; gap:7px; background:#fafbfc; border-top:1px solid var(--border-lt); }

#wizardView { animation:fadeUp .32s ease; }
.page-wrap { display:grid; grid-template-columns:1fr var(--sidebar-w); gap:22px; min-height:80vh; }
.panel { background:var(--surface); border-radius:var(--r-2xl); border:1px solid var(--border); box-shadow:0 8px 32px rgba(0,0,0,.06); display:flex; flex-direction:column; overflow:hidden; }
.panel-header { padding:20px 28px; border-bottom:1px solid var(--border-lt); display:flex; justify-content:space-between; align-items:center; }
.panel-header h1 { font-size:17px; font-weight:800; color:var(--text-1); margin:0; }
.step-nav { display:flex; padding:0 28px; background:#f8fafc; gap:28px; border-bottom:1px solid var(--border); overflow-x:auto; }
.step-item { display:flex; align-items:center; gap:7px; color:var(--text-3); font-weight:700; font-size:12px; cursor:pointer; padding:13px 2px; border-bottom:3px solid transparent; transition:all .2s; white-space:nowrap; }
.step-item.active { color:var(--red); border-bottom-color:var(--red); }
.step-num { width:21px; height:21px; background:#e2e8f0; border-radius:50%; display:grid; place-items:center; font-size:10px; font-weight:700; }
.step-item.active .step-num { background:var(--red); color:#fff; }
.panel-content { flex:1; padding:26px 28px; }
.step-pane { display:none; }
.step-pane.active { display:block; }
.panel-footer { padding:18px 28px; background:#f8fafc; border-top:1px solid var(--border); display:flex; justify-content:space-between; align-items:center; }

.btn { display:inline-flex; align-items:center; gap:7px; padding:10px 20px; border-radius:var(--r-md); font-size:13px; font-weight:700; cursor:pointer; transition:all .18s; border:none; font-family:inherit; text-decoration:none; }
.btn-sm    { padding:6px 13px; font-size:12px; }
.btn-ghost { background:var(--surface); color:var(--text-2); border:1px solid #cbd5e1; }
.btn-ghost:hover { background:#f1f5f9; color:var(--text-1); }
.btn-red   { background:var(--red);  color:#fff; box-shadow:0 3px 12px rgba(220,38,38,.28); }
.btn-red:hover   { background:var(--red-dark); }
.btn-navy  { background:var(--navy); color:#fff; }
.btn-navy:hover  { background:var(--navy-deep); }

.ebys-preview { background:#c8cdd5; border-radius:var(--r-2xl); padding:24px; border:1px solid #94a3b8; }
.ebys-page { width:100%; max-width:540px; min-height:760px; background:#fff; box-shadow:0 10px 36px rgba(0,0,0,.2); padding:52px 46px; display:flex; flex-direction:column; font-family:'Times New Roman',serif; font-size:11pt; line-height:1.6; position:relative; margin:0 auto; }
.ebys-header { display:flex; flex-direction:column; align-items:center; text-align:center; margin-bottom:32px; }
.ebys-logo { width:72px; height:72px; object-fit:contain; margin-bottom:10px; display:block; }
.ebys-header-text { font-size:12pt; font-weight:bold; text-transform:uppercase; }
.ebys-meta { margin-bottom:24px; }
.ebys-body { flex:1; text-align:justify; }
.ebys-footer { margin-top:44px; text-align:right; }

.form-group { margin-bottom:20px; }
.form-label { display:block; font-size:11px; font-weight:700; color:var(--text-1); margin-bottom:7px; text-transform:uppercase; letter-spacing:.5px; }
.form-control { width:100%; padding:12px 15px; border:2px solid var(--border); border-radius:var(--r-md); font-size:13px; background:#f8fafc; }

.school-list-area { display:flex; flex-direction:column; gap:6px; max-height:400px; overflow-y:auto; }
.school-list-item { display:flex; align-items:center; gap:10px; padding:10px 14px; border:1px solid var(--border); border-radius:var(--r-md); cursor:pointer; font-size:13px; font-weight:600; color:var(--text-2); transition:all .15s; user-select:none; }
.school-list-item:hover    { background:var(--red-lt); border-color:var(--red); color:var(--red); }
.school-list-item.selected { background:var(--red-lt); border-color:var(--red); color:var(--red); }
.school-list-item input[type=checkbox] { accent-color:var(--red); width:15px; height:15px; flex-shrink:0; }

@keyframes fadeUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
@media (max-width:1100px) {
  .page-wrap { grid-template-columns:1fr; }
  .ebys-preview { display:none; }
  .dash-stats { grid-template-columns:1fr; }
}
</style>

<div class="page-root">

<% if (!isEdit) { %>
<div id="dashboardView">
  <div class="dash-topbar">
    <div class="dash-topbar-left">
      <div class="dash-topbar-icon"><i class="fas fa-tasks"></i></div>
      <div>
        <h1>Görev Yönetimi</h1>
        <p>Tüm görevleri buradan yönetin ve yeni görev oluşturun.</p>
      </div>
    </div>
    <button type="button" class="btn btn-red" onclick="showWizard()">
      <i class="fas fa-plus-circle"></i> Yeni Görev Oluştur
    </button>
  </div>

  <div class="dash-stats">
    <div class="stat-card">
      <div class="stat-icon navy"><i class="fas fa-layer-group"></i></div>
      <div><div class="stat-num"><%= totalTasks %></div><div class="stat-label">Toplam Görev</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
      <div><div class="stat-num"><%= activeTasks %></div><div class="stat-label">Aktif Görev</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon red"><i class="fas fa-clock"></i></div>
      <div><div class="stat-num"><%= expiredTasks %></div><div class="stat-label">Süresi Dolmuş</div></div>
    </div>
  </div>

  <div class="task-grid">
    <% if (safeTasks.length === 0) { %>
      <div class="stat-card" style="grid-column:1/-1;justify-content:center;padding:40px;">Henüz görev yok.</div>
    <% } %>
    <% safeTasks.forEach(function(t) {
      const deadlineDate = new Date(t.deadline);
      const isExpired    = deadlineDate < new Date();
      const completion   = t.completion_rate || 0;
    %>
      <div class="task-card">
        <div class="card-top">
          <div class="card-status-row">
            <span class="card-badge <%= isExpired ? 'expired' : 'active' %>"><%= isExpired ? 'Süresi Doldu' : 'Aktif' %></span>
            <span class="card-deadline"><i class="fas fa-calendar"></i> <%= deadlineDate.toLocaleDateString('tr-TR') %></span>
          </div>
          <div class="card-title"><%= t.title %></div>
          <div class="progress-label"><span>Tamamlanma</span><span>%<%= completion %></span></div>
          <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:<%= completion %>%"></div></div>
        </div>
        <div class="card-footer">
          <a href="/admin/tasks/<%= t.id %>"      class="btn btn-ghost btn-sm">Detay</a>
          <a href="/admin/tasks/<%= t.id %>/edit" class="btn btn-navy  btn-sm">Düzenle</a>
        </div>
      </div>
    <% }); %>
  </div>
</div>
<% } %>

<div id="wizardView" style="<%= isEdit ? '' : 'display:none;' %>">
  <div class="page-wrap">
    <div class="panel">
      <div class="panel-header">
        <h1><%= isEdit ? 'Görevi Düzenle' : 'Yeni Görev Yaz' %></h1>
        <% if (!isEdit) { %>
          <button type="button" class="btn btn-ghost" onclick="showDashboard()">Geri Dön</button>
        <% } %>
      </div>
      <div class="step-nav">
        <div class="step-item active" data-step="1">1. Bilgiler</div>
        <div class="step-item"        data-step="2">2. Yazı</div>
        <div class="step-item"        data-step="3">3. Form</div>
        <div class="step-item"        data-step="4">4. Dağıtım</div>
      </div>
      <form id="mainForm" action="<%= formAction %>" method="POST" enctype="multipart/form-data" class="panel-content">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="step-pane active" id="step1">
          <div class="form-group"><label class="form-label">Başlık</label><input type="text" name="title" id="inpTitle" class="form-control" value="<%= isEdit ? task.title : '' %>"></div>
          <div class="form-group"><label class="form-label">Sayı</label><input type="text" id="inpSayi" class="form-control"></div>
          <div class="form-group"><label class="form-label">Deadline</label><input type="text" name="deadline" id="taskDeadline" class="form-control" value="<%= isEdit ? task.deadline : '' %>"></div>
        </div>
        <div class="step-pane" id="step2">
          <textarea name="description" id="richEditor"><%= isEdit ? task.description : '' %></textarea>
        </div>
        <div class="step-pane" id="step3">
          <input type="file" name="task_file" class="form-control">
          <div id="fieldsList" style="margin-top:15px"></div>
          <button type="button" class="btn btn-navy btn-sm" onclick="addFormField()" style="margin-top:10px">+ Soru Ekle</button>
        </div>
        <div class="step-pane" id="step4">
          <div class="school-list-area">
            <% schools.forEach(function(s) {
              const checked = isEdit && safeAssignedIds.includes(s.id);
            %>
              <label class="school-list-item <%= checked ? 'selected' : '' %>">
                <input type="checkbox" name="school_ids" value="<%= s.id %>" <%= checked ? 'checked' : '' %>>
                <%= s.full_name %>
              </label>
            <% }); %>
          </div>
        </div>
      </form>
      <div class="panel-footer">
        <button type="button" id="btnPrev"   class="btn btn-ghost" style="visibility:hidden">Geri</button>
        <button type="button" id="btnNext"   class="btn btn-red">Sonraki</button>
        <button type="button" id="btnSubmit" class="btn btn-navy" style="display:none">Gönder</button>
      </div>
    </div>

    <div class="ebys-preview">
      <div class="ebys-page">
        <div class="ebys-header">
          <!-- DÜZELTME: Wikipedia URL kaldırıldı → /icons/mem-logo.jpg kullan -->
          <img src="/icons/mem-logo.jpg" class="ebys-logo" alt="MEM Logo" onerror="this.style.display='none'">
          <div class="ebys-header-text">ELBİSTAN İLÇE MEM</div>
        </div>
        <div class="ebys-meta">
          <div>Sayı: <span id="preSayi">...</span></div>
          <div>Konu: <span id="preKonu">...</span></div>
        </div>
        <div id="preBody" class="ebys-body">...</div>
      </div>
    </div>
  </div>
</div>

</div>

<script>
(function () {
  let step = 1;

  window.showWizard    = () => { document.getElementById('dashboardView').style.display = 'none';  document.getElementById('wizardView').style.display = 'block'; };
  window.showDashboard = () => { document.getElementById('dashboardView').style.display = 'block'; document.getElementById('wizardView').style.display = 'none';  };

  const gotoStep = n => {
    step = n;
    document.querySelectorAll('.step-pane').forEach((p, i) => p.classList.toggle('active', i + 1 === n));
    document.querySelectorAll('.step-item').forEach((it, i) => it.classList.toggle('active', i + 1 === n));
    document.getElementById('btnPrev').style.visibility = n === 1 ? 'hidden' : 'visible';
    document.getElementById('btnNext').style.display    = n === 4 ? 'none' : 'inline-flex';
    document.getElementById('btnSubmit').style.display  = n === 4 ? 'inline-flex' : 'none';
  };

  document.getElementById('btnNext').onclick   = () => step < 4 && gotoStep(step + 1);
  document.getElementById('btnPrev').onclick   = () => step > 1 && gotoStep(step - 1);
  document.getElementById('btnSubmit').onclick = () => document.getElementById('mainForm').submit();

  ClassicEditor.create(document.querySelector('#richEditor'))
    .then(ed => ed.model.document.on('change:data', () => {
      document.getElementById('preBody').innerHTML = ed.getData();
    }))
    .catch(err => console.log('CKEditor Error:', err));

  flatpickr('#taskDeadline', { locale: 'tr' });

  document.getElementById('inpTitle').oninput = e => document.getElementById('preKonu').textContent = e.target.value;
  document.getElementById('inpSayi').oninput  = e => document.getElementById('preSayi').textContent = e.target.value;

  document.querySelectorAll('.school-list-item').forEach(label => {
    label.addEventListener('change', () => {
      label.classList.toggle('selected', label.querySelector('input[type=checkbox]').checked);
    });
  });

  window.addFormField = (data = null) => {
    const div = document.createElement('div');
    div.innerHTML = `<input type="text" name="field_labels" class="form-control" value="${data ? data.field_label : ''}" placeholder="Soru..." style="margin-bottom:5px">`;
    document.getElementById('fieldsList').appendChild(div);
  };
})();
</script>

<%- include('../layouts/footer') %>
