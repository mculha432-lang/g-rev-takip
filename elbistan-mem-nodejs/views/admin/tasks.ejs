<%- include('../layouts/header') %>

<!-- CSS & JS Assets -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://npmcdn.com/flatpickr/dist/l10n/tr.js"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>

<%
  const safeTasks = typeof tasks !== 'undefined' ? tasks : [];
  const totalTasks = safeTasks.length;
  const activeTasks = safeTasks.filter(t => new Date(t.deadline) >= new Date()).length;
  const expiredTasks = totalTasks - activeTasks;
%>

<style>
    :root {
        --red: #dc2626; --red-dark: #b91c1c; --red-muted: #fef2f2; --red-border: #fecaca;
        --blue: #2563eb; --blue-muted: #eff6ff; --blue-border: #dbeafe;
        --green: #059669; --green-muted: #ecfdf5; --green-border: #d1fae5;
        --navy: #1e293b; --navy-deep: #0f172a;
        --surface: #ffffff; --bg: #f8fafc;
        --border: #e2e8f0; --border-lt: #f1f5f9;
        --text-1: #1e293b; --text-2: #475569; --text-3: #94a3b8;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.07);
        --shadow-md: 0 4px 16px rgba(0,0,0,.08);
        --shadow-lg: 0 20px 50px rgba(0,0,0,.14);
        --r-sm: 8px; --r-md: 12px; --r-lg: 16px; --r-xl: 20px;
        --font: 'Plus Jakarta Sans', sans-serif;
    }

    .tp { font-family: var(--font); color: var(--text-1); -webkit-font-smoothing: antialiased; }
    .page-root { margin-top: 18px; }

    /* ── Dashboard Stats ── */
    .tp .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px; }
    .tp .stat-card {
        background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg);
        padding: 20px 22px; display: flex; align-items: center; gap: 16px;
        box-shadow: var(--shadow-sm); transition: transform .2s, box-shadow .2s;
    }
    .tp .stat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .tp .stat-icon { width: 48px; height: 48px; border-radius: var(--r-md); display: grid; place-items: center; font-size: 20px; flex-shrink: 0; }
    .tp .stat-icon.navy { background: var(--blue-muted); color: var(--blue); }
    .tp .stat-icon.green { background: var(--green-muted); color: var(--green); }
    .tp .stat-icon.red { background: var(--red-muted); color: var(--red); }
    .tp .stat-info h3 { font-size: 28px; font-weight: 800; line-height: 1; margin: 0; }
    .tp .stat-info p { font-size: 11px; font-weight: 700; color: var(--text-3); text-transform: uppercase; letter-spacing: .5px; margin-top: 5px; }

    /* ── Task Grid ── */
    .tp .task-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 18px; }
    .tp .task-card {
        background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-xl);
        overflow: hidden; box-shadow: var(--shadow-sm); display: flex; flex-direction: column;
        transition: transform .25s, box-shadow .25s;
    }
    .tp .task-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
    .tp .card-top { padding: 20px 22px; flex: 1; }
    .tp .card-status-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
    .tp .badge { font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: .5px; }
    .tp .badge-active { background: var(--green-muted); color: var(--green); border: 1px solid var(--green-border); }
    .tp .badge-expired { background: var(--red-muted); color: var(--red); border: 1px solid var(--red-border); }
    .tp .card-title { font-size: 15px; font-weight: 700; color: var(--text-1); line-height: 1.5; margin-bottom: 16px; }
    .tp .card-footer { background: #fcfdfe; padding: 14px 18px; border-top: 1px solid var(--border-lt); display: flex; gap: 8px; }

    /* ── Wizard Layout ── */
    .tp .wizard-wrap { display: block; max-width: 960px; margin: 0 auto; min-height: 85vh; padding-bottom: 40px; }
    .tp .wizard-panel {
        background: var(--surface); border-radius: var(--r-xl); border: 1px solid var(--border);
        box-shadow: var(--shadow-lg); display: flex; flex-direction: column; overflow: hidden;
    }
    .tp .wizard-header { padding: 22px 32px; border-bottom: 1px solid var(--border-lt); display: flex; justify-content: space-between; align-items: center; background: #fff; }
    .tp .wizard-header h2 { font-size: 20px; font-weight: 800; margin: 0; color: var(--navy); }
    
    .tp .step-nav { display: flex; background: #f8fafc; border-bottom: 1px solid var(--border); padding: 0 32px; gap: 40px; overflow-x: auto; }
    .tp .step-item {
        display: flex; align-items: center; gap: 12px; padding: 18px 0;
        font-size: 14px; font-weight: 700; color: var(--text-3); cursor: pointer;
        border-bottom: 3px solid transparent; transition: all .2s; white-space: nowrap;
    }
    .tp .step-item.active { color: var(--red); border-bottom-color: var(--red); }
    .tp .step-icon { width: 28px; height: 28px; border-radius: 8px; background: #e2e8f0; display: grid; place-items: center; font-size: 12px; font-weight: 800; }
    .tp .step-item.active .step-icon { background: var(--red); color: #fff; }

    .tp .step-content { flex: 1; padding: 36px 48px; background: #fff; }
    .tp .step-pane { display: none; }
    .tp .step-pane.active { display: block; animation: fadeUp .3s ease; }

    /* ── Forms ── */
    .tp .form-group { margin-bottom: 26px; }
    .tp .form-label { display: block; font-size: 11px; font-weight: 800; color: var(--text-2); margin-bottom: 10px; text-transform: uppercase; letter-spacing: .8px; }
    .tp .form-control {
        width: 100%; padding: 14px 18px; border: 2px solid var(--border); border-radius: var(--r-md);
        font-family: inherit; font-size: 14px; background: #f8fafc; transition: all .2s; box-sizing: border-box;
    }
    .tp .form-control:focus { outline: none; border-color: var(--blue); background: #fff; box-shadow: 0 0 0 5px rgba(37,99,235,.06); }
    
    /* ── School Search & Picker ── */
    .tp .school-picker { border: 2px solid var(--border); border-radius: var(--r-md); overflow: hidden; background: #f8fafc; }
    .tp .school-search { padding: 14px; border-bottom: 1px solid var(--border); display: flex; gap: 12px; background: #fff; }
    .tp .school-list { max-height: 440px; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 6px; }
    .tp .school-item {
        display: flex; align-items: center; gap: 14px; padding: 12px 16px;
        border-radius: var(--r-md); cursor: pointer; transition: all .15s; border: 1px solid transparent;
    }
    .tp .school-item:hover { background: #f1f5f9; }
    .tp .school-item input { width: 20px; height: 20px; cursor: pointer; accent-color: var(--red); }
    .tp .school-item.selected { background: var(--red-muted); color: var(--red); font-weight: 700; border-color: var(--red-border); }

    /* ── Utilities ── */
    .btn {
        display: inline-flex; align-items: center; gap: 10px; padding: 12px 26px;
        border-radius: var(--r-md); font-size: 14px; font-weight: 700; cursor: pointer;
        transition: all .2s; border: none; font-family: inherit; text-decoration: none;
    }
    .btn-red { background: var(--red); color: #fff; box-shadow: 0 4px 14px rgba(220,38,38,.25); }
    .btn-red:hover { background: var(--red-dark); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(220,38,38,.35); }
    .btn-navy { background: var(--navy); color: #fff; }
    .btn-navy:hover { background: var(--navy-deep); }
    .btn-ghost { background: transparent; color: var(--text-2); border: 2px solid var(--border); }
    .btn-ghost:hover { background: #f1f5f9; color: var(--text-1); border-color: #cbd5e1; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="tp page-root">

    <!-- Dashboard View -->
    <div id="dashboardView">
        <div class="dash-topbar" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:28px;">
            <div>
                <h1 style="font-size:26px; font-weight:800; margin:0; color:var(--navy);">Görev Yönetimi</h1>
                <p style="color:var(--text-3); font-size:14px; margin:6px 0 0; font-weight:500;">Kurum genelindeki görevleri ve okul yanıtlarını takip edin.</p>
            </div>
            <button class="btn btn-red" onclick="switchView('wizard')">
                <i class="fas fa-plus-circle"></i> Yeni Görev Oluştur
            </button>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon navy"><i class="fas fa-folder-open"></i></div>
                <div class="stat-info"><h3><%= totalTasks %></h3><p>Toplam Görev</p></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
                <div class="stat-info"><h3><%= activeTasks %></h3><p>Aktif Görevler</p></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon red"><i class="fas fa-history"></i></div>
                <div class="stat-info"><h3><%= expiredTasks %></h3><p>Süresi Dolanlar</p></div>
            </div>
        </div>

        <div class="task-grid">
            <% if (safeTasks.length === 0) { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 70px; background: #fff; border-radius: 20px; border: 2px dashed var(--border);">
                    <i class="fas fa-clipboard-list" style="font-size: 56px; color: var(--border); margin-bottom: 20px; display: block;"></i>
                    <p style="color: var(--text-3); font-weight: 600; font-size:15px;">Henüz hiç görev oluşturulmadı.</p>
                </div>
            <% } %>
            <% safeTasks.forEach(t => { 
                const isExpired = new Date(t.deadline) < new Date();
            %>
                <div class="task-card">
                    <div class="card-top">
                        <div class="card-status-row">
                            <span class="badge <%= isExpired ? 'badge-expired' : 'badge-active' %>">
                                <%= isExpired ? 'Süresi Doldu' : 'Aktif' %>
                            </span>
                            <span style="font-size:11px; font-weight:800; color:var(--text-3);">
                                <i class="fas fa-calendar-alt"></i> <%= new Date(t.deadline).toLocaleDateString('tr-TR') %>
                            </span>
                        </div>
                        <div class="card-title"><%= t.title %></div>
                        <div style="margin-top:auto;">
                            <div style="display:flex; justify-content:space-between; font-size:11px; font-weight:800; color:var(--text-2); margin-bottom:8px;">
                                <span>Tamamlanma Oranı</span>
                                <span>%<%= t.completion_rate || 0 %></span>
                            </div>
                            <div style="height:7px; background:var(--border-lt); border-radius:10px; overflow:hidden;">
                                <div style="width:<%= t.completion_rate || 0 %>%; height:100%; background:linear-gradient(90deg, var(--green), #34d399); border-radius:10px;"></div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="/admin/tasks/<%= t.id %>" class="btn btn-navy btn-sm" style="flex:1; justify-content:center;">Takip Et</a>
                        <a href="/admin/tasks/<%= t.id %>/edit" class="btn btn-ghost btn-sm" title="Düzenle"><i class="fas fa-pencil-alt"></i></a>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Wizard View -->
    <div id="wizardView" style="display:none">
        <div class="wizard-wrap">
            <div class="wizard-panel">
                <div class="wizard-header">
                    <h2><i class="fas fa-pen-nib" style="color:var(--red); margin-right:12px;"></i> Yeni Görev Yaz</h2>
                    <button class="btn btn-ghost btn-sm" onclick="switchView('dashboard')">Listeye Dön</button>
                </div>

                <div class="step-nav">
                    <div class="step-item active" data-step="1"><div class="step-icon">1</div> Temel Bilgiler</div>
                    <div class="step-item" data-step="2"><div class="step-icon">2</div> Görev Metni</div>
                    <div class="step-item" data-step="3"><div class="step-icon">3</div> Form & Dosya</div>
                    <div class="step-item" data-step="4"><div class="step-icon">4</div> Okul Seçimi</div>
                </div>

                <form id="taskForm" action="/admin/tasks" method="POST" enctype="multipart/form-data" class="step-content">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    
                    <!-- Step 1: Meta -->
                    <div class="step-pane active" id="pane-1">
                        <div class="form-group">
                            <label class="form-label">Görev Başlığı / Konusu</label>
                            <input type="text" name="title" id="mainTitle" class="form-control" placeholder="Örn: 2024 Yılı Taşımalı Eğitim Veri Girişi" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Dosya / Sayı Numarası (Opsiyonel)</label>
                            <input type="text" name="ebys_no" class="form-control" placeholder="Örn: 12345678-100-E.12345">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Son Teslim Tarihi ve Saati</label>
                            <input type="text" name="deadline" id="deadlinePicker" class="form-control" placeholder="Tarih seçiniz..." required>
                        </div>
                    </div>

                    <!-- Step 2: Content -->
                    <div class="step-pane" id="pane-2">
                        <div class="form-group">
                            <label class="form-label">Okullara Gönderilecek Resmî Yazı Metni</label>
                            <textarea name="description" id="editor"></textarea>
                        </div>
                    </div>

                    <!-- Step 3: Requirements -->
                    <div class="step-pane" id="pane-3">
                        <div class="card" style="padding: 28px; background: #fdfdfd; margin-bottom: 28px; border: 2px dashed var(--border); border-radius:16px;">
                            <label class="form-label">Ek Dosya Yükle (Okulların indirmesi için)</label>
                            <input type="file" name="task_file" class="form-control" style="background: #fff; border: 1px solid var(--border);">
                            <p style="font-size: 11px; color: var(--text-3); margin-top: 10px; font-weight:500;">
                                <i class="fas fa-info-circle" style="color:var(--blue);"></i> Görevle ilgili varsa taranmış resmî yazı veya ekleri buradan yükleyin.
                            </p>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; padding: 20px; background: var(--border-lt); border-radius: 14px; border: 1px solid var(--border);">
                            <label style="display: flex; align-items: center; gap: 12px; cursor: pointer;">
                                <input type="checkbox" name="requires_file" value="1" style="width:22px;height:22px;">
                                <div style="display:flex; flex-direction:column;">
                                    <span style="font-size:14px; font-weight:800; color:var(--navy);">Okullar Dosya Yüklesin</span>
                                    <span style="font-size:11px; color:var(--text-3); font-weight:600;">Okulun panele belge yüklemesini ister misiniz?</span>
                                </div>
                            </label>
                            <label style="display: flex; align-items: center; gap: 12px; cursor: pointer;">
                                <input type="checkbox" name="is_file_mandatory" value="1" style="width:22px;height:22px;">
                                <div style="display:flex; flex-direction:column;">
                                    <span style="font-size:14px; font-weight:800; color:var(--navy);">Dosya Yükleme Zorunlu</span>
                                    <span style="font-size:11px; color:var(--text-3); font-weight:600;">Dosya yüklemeden görev tamamlanmasın.</span>
                                </div>
                            </label>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Veri Giriş Formu Oluştur (Dinamik Alanlar)</label>
                            <div id="dynamicFields" style="display:flex; flex-direction:column; gap:14px;"></div>
                            <button type="button" class="btn btn-ghost" style="margin-top:14px; width:100%; border-style:dashed; padding:14px; color:var(--blue);" onclick="addField()">
                                <i class="fas fa-plus-circle"></i> Yeni Soru / Veri Alanı Ekle
                            </button>
                        </div>
                    </div>

                    <!-- Step 4: Distribution -->
                    <div class="step-pane" id="pane-4">
                        <div class="school-picker">
                            <div class="school-search">
                                <i class="fas fa-search" style="color:var(--text-3); align-self:center; margin-left:10px;"></i>
                                <input type="text" id="schoolSearch" class="form-control" style="border:none; background:transparent;" placeholder="Hangi okullara gönderilecek? Ara...">
                                <button type="button" class="btn btn-navy btn-sm" onclick="toggleAllSchools(true)">Tümünü Seç</button>
                                <button type="button" class="btn btn-ghost btn-sm" onclick="toggleAllSchools(false)">Temizle</button>
                            </div>
                            <div class="school-list" id="schoolList">
                                <% schools.forEach(s => { %>
                                    <label class="school-item" data-name="<%= s.full_name.toLowerCase() %>">
                                        <input type="checkbox" name="school_ids" value="<%= s.id %>">
                                        <span style="font-size:14px; font-weight:600;"><%= s.full_name %></span>
                                    </label>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </form>

                <div class="wizard-footer" style="padding: 26px 48px; background: #f8fafc; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items:center;">
                    <button type="button" id="btnPrev" class="btn btn-ghost" style="visibility:hidden">
                        <i class="fas fa-chevron-left"></i> Önceki Adım
                    </button>
                    <div>
                        <button type="button" id="btnNext" class="btn btn-red" style="padding:14px 32px;">
                            Sonraki Adım <i class="fas fa-chevron-right" style="margin-left:10px;"></i>
                        </button>
                        <button type="button" id="btnSubmit" class="btn btn-navy" style="display:none; padding:14px 36px; background:var(--green); border-color:var(--green);">
                            Görevi Yayınla <i class="fas fa-paper-plane" style="margin-left:10px;"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
(function() {
    'use strict';
    let currentStep = 1;

    // View Switching
    window.switchView = (mode) => {
        const dash = document.getElementById('dashboardView');
        const wiz  = document.getElementById('wizardView');
        if (mode === 'wizard') {
            dash.style.display = 'none';
            wiz.style.display  = 'block';
        } else {
            dash.style.display = 'block';
            wiz.style.display  = 'none';
            gotoStep(1);
        }
    };

    // Wizard Navigation
    const gotoStep = (n) => {
        currentStep = n;
        document.querySelectorAll('.step-pane').forEach((p, i) => p.classList.toggle('active', (i+1) === n));
        document.querySelectorAll('.step-item').forEach((it, i) => it.classList.toggle('active', (i+1) === n));
        
        const btnPrev   = document.getElementById('btnPrev');
        const btnNext   = document.getElementById('btnNext');
        const btnSubmit = document.getElementById('btnSubmit');

        btnPrev.style.visibility = n === 1 ? 'hidden' : 'visible';
        btnNext.style.display    = n === 4 ? 'none' : 'inline-flex';
        btnSubmit.style.display  = n === 4 ? 'inline-flex' : 'none';
        
        // Scroll to top of wizard
        document.getElementById('wizardView').scrollIntoView({ behavior: 'smooth' });
    };

    document.getElementById('btnNext').onclick = () => { if(currentStep < 4) gotoStep(currentStep + 1); };
    document.getElementById('btnPrev').onclick = () => { if(currentStep > 1) gotoStep(currentStep - 1); };
    document.getElementById('btnSubmit').onclick = () => {
        // Validation check
        const title = document.getElementById('mainTitle').value;
        if (!title) { alert('Lütfen görev başlığını giriniz.'); gotoStep(1); return; }
        
        const schools = document.querySelectorAll('input[name="school_ids"]:checked');
        if (schools.length === 0) { alert('Lütfen en az bir okul seçiniz.'); gotoStep(4); return; }

        document.getElementById('taskForm').submit();
    };

    // Editor
    ClassicEditor.create(document.querySelector('#editor'), {
        language: 'tr',
        toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'insertTable', 'undo', 'redo']
    }).catch(err => console.error(err));

    // Date Picker
    flatpickr("#deadlinePicker", {
        enableTime: true,
        dateFormat: "Y-m-d H:i",
        locale: "tr",
        minDate: "today",
        time_24hr: true
    });

    // Dynamic Fields
    window.addField = () => {
        const container = document.getElementById('dynamicFields');
        const div = document.createElement('div');
        div.className = 'field-item';
        div.style.cssText = 'display:flex; gap:14px; align-items:center; background:#f1f5f9; padding:15px; border-radius:12px; animation:fadeUp 0.35s ease; border:1px solid var(--border);';
        div.innerHTML = `
            <input type="hidden" name="field_ids" value="">
            <div style="flex-shrink:0;">
                <select name="field_types" class="form-control" style="width:130px; font-weight:700;">
                    <option value="text">Metin</option>
                    <option value="number">Sayı</option>
                    <option value="date">Tarih</option>
                </select>
            </div>
            <div style="flex:1;">
                <input type="text" name="field_labels" class="form-control" placeholder="Soru veya veri alanı başlığını giriniz..." required>
            </div>
            <button type="button" onclick="this.parentElement.remove()" style="background:#fee2e2; border:none; color:var(--red); cursor:pointer; width:40px; height:40px; border-radius:10px; display:grid; place-items:center; transition:background 0.2s;"><i class="fas fa-trash"></i></button>
        `;
        container.appendChild(div);
    };

    // School Picker Logic
    const schoolSearch = document.getElementById('schoolSearch');
    schoolSearch.oninput = (e) => {
        const term = e.target.value.toLowerCase();
        document.querySelectorAll('.school-item').forEach(item => {
            const visible = item.dataset.name.includes(term);
            item.style.display = visible ? 'flex' : 'none';
        });
    };

    window.toggleAllSchools = (status) => {
        document.querySelectorAll('.school-item').forEach(item => {
            if (item.style.display !== 'none') {
                const cb = item.querySelector('input');
                cb.checked = status;
                item.classList.toggle('selected', status);
            }
        });
    };

    document.getElementById('schoolList').addEventListener('change', (e) => {
        if (e.target.tagName === 'INPUT') {
            e.target.closest('.school-item').classList.toggle('selected', e.target.checked);
        }
    });

})();
</script>

<%- include('../layouts/footer') %>
