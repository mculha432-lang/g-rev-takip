<%- include('../layouts/header') %>

    <link rel="stylesheet" href="/css/admin_schools.css">

    <div class="page-header">
        <div class="page-header-left">
            <div class="page-header-icon">
                <i class="fas fa-university"></i>
            </div>
            <div>
                <h1>Okul Yönetimi</h1>
                <p>İlçedeki okulları yönetin ve özelliklerini belirleyin.</p>
            </div>
        </div>
        <div class="page-header-stats">
            <div class="page-header-stat">
                <div class="page-header-stat-value">
                    <%= schools.length %>
                </div>
                <div class="page-header-stat-label">Toplam Okul</div>
            </div>
        </div>
    </div>

    <% if(status==='success' ) { %>
        <div class="alert alert-success"
            style="background: #ecfdf5; color: #059669; padding: 12px; border-radius: 8px; margin-bottom: 15px; font-size: 13px;">
            <i class="fas fa-check-circle"></i> Okul başarıyla eklendi!
        </div>
        <% } else if(status==='updated' ) { %>
            <div class="alert alert-success"
                style="background: #ecfdf5; color: #059669; padding: 12px; border-radius: 8px; margin-bottom: 15px; font-size: 13px;">
                <i class="fas fa-check-circle"></i> Okul başarıyla güncellendi!
            </div>
            <% } else if(status==='exists' ) { %>
                <div class="alert alert-danger"
                    style="background: #fef2f2; color: #dc2626; padding: 12px; border-radius: 8px; margin-bottom: 15px; font-size: 13px;">
                    <i class="fas fa-exclamation-circle"></i> Bu kurum kodu zaten kullanılıyor!
                </div>
                <% } else if(status==='deleted' ) { %>
                    <div class="alert alert-success"
                        style="background: #ecfdf5; color: #059669; padding: 12px; border-radius: 8px; margin-bottom: 15px; font-size: 13px;">
                        <i class="fas fa-check-circle"></i> Okul silindi!
                    </div>
                    <% } else if(status==='manager_granted' ) { %>
                        <div class="alert alert-success"
                            style="background: #fffbeb; color: #92400e; padding: 12px; border-radius: 8px; margin-bottom: 15px; font-size: 13px; border: 1px solid #fde68a;">
                            <i class="fas fa-shield-alt"></i> Kurum başarıyla <strong>Kurum Yöneticisi</strong> olarak
                            yetkilendirildi!
                        </div>
                        <% } else if(status==='password_reset' ) { %>
                        <div class="alert alert-success"
                            style="background: #eff6ff; color: #1e40af; padding: 12px; border-radius: 8px; margin-bottom: 15px; font-size: 13px; border: 1px solid #bfdbfe;">
                            <i class="fas fa-key"></i> Kurumun şifresi başarıyla <strong>Kurum Kodu</strong> olarak sıfırlandı!
                        </div>
                        <% } else if(status==='manager_revoked' ) { %>
                            <div class="alert alert-warning"
                                style="background: #fff7ed; color: #c2410c; padding: 12px; border-radius: 8px; margin-bottom: 15px; font-size: 13px; border: 1px solid #fed7aa;">
                                <i class="fas fa-user-times"></i> Kurumun <strong>Kurum Yöneticisi</strong> yetkisi
                                kaldırıldı.
                            </div>
                            <% } %>

                                <!-- Filtreleme Alanı -->
                                <form action="/admin/schools" method="GET" class="filter-bar">
                                    <div class="filter-item">
                                        <label>Arama</label>
                                        <input type="text" name="search" class="form-control"
                                            placeholder="Okul adı veya kodu..."
                                            value="<%= typeof filters !== 'undefined' ? filters.search : '' %>">
                                    </div>
                                    <div class="filter-item">
                                        <label>Okul Türü</label>
                                        <select name="type" class="form-select">
                                            <option value="all">Tümü</option>
                                            <option value="anaokulu" <%=typeof filters !=='undefined' &&
                                                filters.type==='anaokulu' ? 'selected' : '' %>>Anaokulu</option>
                                            <option value="ilkokul" <%=typeof filters !=='undefined' &&
                                                filters.type==='ilkokul' ? 'selected' : '' %>>İlkokul</option>
                                            <option value="ortaokul" <%=typeof filters !=='undefined' &&
                                                filters.type==='ortaokul' ? 'selected' : '' %>>Ortaokul</option>
                                            <option value="lise" <%=typeof filters !=='undefined' &&
                                                filters.type==='lise' ? 'selected' : '' %>>Lise</option>
                                            <option value="surucu_kursu" <%=typeof filters !=='undefined' &&
                                                filters.type==='surucu_kursu' ? 'selected' : '' %>>Sürücü Kursu</option>
                                            <option value="kurs" <%=typeof filters !=='undefined' &&
                                                filters.type==='kurs' ? 'selected' : '' %>>Özel Kurs</option>
                                            <option value="rehabilitasyon" <%=typeof filters !=='undefined' &&
                                                filters.type==='rehabilitasyon' ? 'selected' : '' %>>Rehabilitasyon
                                            </option>
                                            <option value="yurt" <%=typeof filters !=='undefined' &&
                                                filters.type==='yurt' ? 'selected' : '' %>>Özel Yurt</option>
                                            <option value="diger" <%=typeof filters !=='undefined' &&
                                                filters.type==='diger' ? 'selected' : '' %>>Diğer</option>
                                        </select>
                                    </div>
                                    <div class="filter-item" style="max-width: 200px;">
                                        <label>Özellikler</label>
                                        <div style="display: flex; gap: 10px; margin-top: 8px;">
                                            <label class="custom-checkbox" style="margin: 0;">
                                                <input type="checkbox" name="has_pension" value="1" <%=typeof filters
                                                    !=='undefined' && filters.has_pension==='1' ? 'checked' : '' %>>
                                                <span>Pansiyon</span>
                                            </label>
                                            <label class="custom-checkbox" style="margin: 0;">
                                                <input type="checkbox" name="has_canteen" value="1" <%=typeof filters
                                                    !=='undefined' && filters.has_canteen==='1' ? 'checked' : '' %>>
                                                <span>Kantin</span>
                                            </label>
                                        </div>
                                    </div>
                                    <button type="submit" class="btn-filter"><i class="fas fa-filter"></i>
                                        Filtrele</button>
                                    <% if(typeof filters !=='undefined' && (filters.search || filters.type &&
                                        filters.type !=='all' || filters.has_pension || filters.has_canteen)) { %>
                                        <a href="/admin/schools"
                                            style="margin-bottom: 10px; font-size: 13px; color: #ef4444; font-weight: 600; align-self: center; margin-left: auto;">Temizle</a>
                                        <% } %>
                                </form>

                                <div class="content-grid">
                                    <!-- Okul Listesi -->
                                    <div class="card">
                                        <div class="card-header">
                                            <div><i class="fas fa-list"></i> Okul Listesi</div>
                                            <div style="font-size: 12px; color: #64748b; font-weight: normal;">Toplam:
                                                <%= schools.length %>
                                            </div>
                                        </div>
                                        <div class="card-body table-container">
                                            <table>
                                                <thead>
                                                    <tr>
                                                        <th>Kurum Kodu</th>
                                                        <th>Okul Adı</th>
                                                        <th>Türü</th>
                                                        <th>Özellikler</th>
                                                        <th style="text-align: right;">İşlemler</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% schools.forEach(school=> { %>
                                                        <tr>
                                                            <td><span style="font-family: monospace; font-weight: 600;">
                                                                    <%= school.username %>
                                                                </span></td>
                                                            <td>
                                                                <%= school.full_name %>
                                                                    <% if(school.is_manager===1) { %>
                                                                        <span class="manager-badge"><i
                                                                                class="fas fa-shield-alt"></i> Kurum
                                                                            Yöneticisi</span>
                                                                        <% } %>
                                                            </td>
                                                            <td>
                                                                <span class="badge badge-type">
                                                                    <% if(school.school_type==='anaokulu' ) { %>
                                                                        Anaokulu
                                                                        <% } else if(school.school_type==='ilkokul' ) {
                                                                            %>
                                                                            İlkokul
                                                                            <% } else if(school.school_type==='ortaokul'
                                                                                ) { %>
                                                                                Ortaokul
                                                                                <% } else if(school.school_type==='lise'
                                                                                    ) { %>
                                                                                    Lise
                                                                                    <% } else
                                                                                        if(school.school_type==='surucu_kursu'
                                                                                        ) { %>
                                                                                        Sürücü Kursu
                                                                                        <% } else
                                                                                            if(school.school_type==='kurs'
                                                                                            ) { %>
                                                                                            Özel Kurs
                                                                                            <% } else
                                                                                                if(school.school_type==='rehabilitasyon'
                                                                                                ) { %>
                                                                                                Rehabilitasyon
                                                                                                <% } else
                                                                                                    if(school.school_type==='yurt'
                                                                                                    ) { %>
                                                                                                    Özel Yurt
                                                                                                    <% } else { %> Diğer
                                                                                                        <% } %>
                                                                </span>
                                                            </td>
                                                            <td>
                                                                <% if(school.has_pension) { %>
                                                                    <span class="feature-badge feature-pension"
                                                                        title="Pansiyon Var"><i class="fas fa-bed"></i>
                                                                        Pansiyon</span>
                                                                    <% } %>
                                                                        <% if(school.has_canteen) { %>
                                                                            <span class="feature-badge feature-canteen"
                                                                                title="Kantin Var"><i
                                                                                    class="fas fa-utensils"></i>
                                                                                Kantin</span>
                                                                            <% } %>
                                                                                <% if(!school.has_pension &&
                                                                                    !school.has_canteen) { %>
                                                                                    <span
                                                                                        style="color: #cbd5e1; font-size: 11px;">-</span>
                                                                                    <% } %>
                                                            </td>
                                                            <td style="text-align: right;">
                                                                <div class="action-buttons">
                                                                    <a href="/admin/schools/<%= school.id %>/edit"
                                                                        class="btn-action btn-edit" title="Düzenle">
                                                                        <i class="fas fa-edit"></i>
                                                                    </a>
                                                                    <form
                                                                        action="/admin/schools/<%= school.id %>/reset-password"
                                                                        method="POST" style="display: inline;"
                                                                        onsubmit="return confirm('Bu kurumun şifresini BAŞLANGIÇ ŞİFRESİ (Kurum Kodu) olarak sıfırlamak istediğinize emin misiniz?')">
                                                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                                        <button type="submit" class="btn-action" style="color: #3b82f6; background: #eff6ff; border: 1px solid #bfdbfe; margin-left: 5px;" title="Şifreyi Sıfırla">
                                                                            <i class="fas fa-key"></i>
                                                                        </button>
                                                                    </form>
                                                                    <form
                                                                        action="/admin/schools/<%= school.id %>/toggle-manager"
                                                                        method="POST" style="display: inline;"
                                                                        onsubmit="return confirm('<%= school.is_manager === 1 ? 'Bu kurumun yönetici yetkisini kaldırmak istediğinize emin misiniz?' : 'Bu kurumu Kurum Yöneticisi yapmak istediğinize emin misiniz? Admin paneline erişim yetkisi verilecektir.' %>')">
                                                                        <input type="hidden" name="_csrf"
                                                                            value="<%= csrfToken %>">
                                                                        <button type="submit"
                                                                            class="btn-action btn-manager <%= school.is_manager === 1 ? 'active-manager' : '' %>"
                                                                            title="<%= school.is_manager === 1 ? 'Yönetici Yetkisini Kaldır' : 'Kurum Yöneticisi Yap' %>">
                                                                            <i class="fas fa-shield-alt"></i>
                                                                        </button>
                                                                    </form>
                                                                    <form
                                                                        action="/admin/schools/<%= school.id %>/delete"
                                                                        method="POST" style="display: inline;"
                                                                        onsubmit="return confirm('Bu okulu silmek istediğinize emin misiniz?')">
                                                                        <input type="hidden" name="_csrf"
                                                                            value="<%= csrfToken %>">
                                                                        <button type="submit"
                                                                            class="btn-action btn-delete" title="Sil">
                                                                            <i class="fas fa-trash"></i>
                                                                        </button>
                                                                    </form>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <% }) %>
                                                            <% if(schools.length===0) { %>
                                                                <tr>
                                                                    <td colspan="5"
                                                                        style="text-align: center; padding: 40px; color: #94a3b8;">
                                                                        <i class="fas fa-search"
                                                                            style="font-size: 32px; margin-bottom: 10px; display: block; opacity: 0.5;"></i>
                                                                        Kayıt bulunamadı.
                                                                    </td>
                                                                </tr>
                                                                <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>

                                    <!-- Okul Ekleme/Düzenleme Formu -->
                                    <div class="card form-card">
                                        <h3
                                            style="margin: 0 0 20px 0; font-size: 16px; color: #0f172a; display: flex; align-items: center; gap: 8px;">
                                            <% if(editSchool) { %>
                                                <i class="fas fa-edit" style="color: #f59e0b;"></i> Okulu Düzenle
                                                <% } else { %>
                                                    <i class="fas fa-plus-circle" style="color: #E31E24;"></i> Yeni Okul
                                                    Ekle
                                                    <% } %>
                                        </h3>

                                        <form
                                            action="<%= editSchool ? '/admin/schools/' + editSchool.id + '/update' : '/admin/schools' %>"
                                            method="POST">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <div class="form-group">
                                                <label>Kurum Kodu (Kullanıcı Adı)</label>
                                                <input type="text" name="username" class="form-control" required
                                                    value="<%= editSchool ? editSchool.username : '' %>"
                                                    placeholder="Örn: 123456">
                                            </div>

                                            <div class="form-group">
                                                <label>Okul Adı</label>
                                                <input type="text" name="full_name" class="form-control" required
                                                    value="<%= editSchool ? editSchool.full_name : '' %>"
                                                    placeholder="Örn: Cumhuriyet İlkokulu">
                                            </div>

                                            <div class="form-group">
                                                <label>Okul Türü</label>
                                                <select name="school_type" class="form-select" required>
                                                    <option value="anaokulu" <%=editSchool &&
                                                        editSchool.school_type==='anaokulu' ? 'selected' : '' %>
                                                        >Anaokulu
                                                    </option>
                                                    <option value="ilkokul" <%=editSchool &&
                                                        editSchool.school_type==='ilkokul' ? 'selected' : '' %>>İlkokul
                                                    </option>
                                                    <option value="ortaokul" <%=editSchool &&
                                                        editSchool.school_type==='ortaokul' ? 'selected' : '' %>
                                                        >Ortaokul
                                                    </option>
                                                    <option value="lise" <%=editSchool &&
                                                        editSchool.school_type==='lise' ? 'selected' : '' %>>Lise
                                                    </option>
                                                    <option value="surucu_kursu" <%=editSchool &&
                                                        editSchool.school_type==='surucu_kursu' ? 'selected' : '' %>
                                                        >Sürücü
                                                        Kursu</option>
                                                    <option value="kurs" <%=editSchool &&
                                                        editSchool.school_type==='kurs' ? 'selected' : '' %>>Özel Kurs
                                                    </option>
                                                    <option value="rehabilitasyon" <%=editSchool &&
                                                        editSchool.school_type==='rehabilitasyon' ? 'selected' : '' %>
                                                        >Rehabilitasyon</option>
                                                    <option value="yurt" <%=editSchool &&
                                                        editSchool.school_type==='yurt' ? 'selected' : '' %>>Özel Yurt
                                                    </option>
                                                    <option value="diger" <%=editSchool &&
                                                        editSchool.school_type==='diger' ? 'selected' : '' %>>Diğer
                                                    </option>
                                                </select>
                                            </div>

                                            <div class="form-group">
                                                <label>Ek Özellikler</label>
                                                <div class="checkbox-group">
                                                    <label class="custom-checkbox">
                                                        <input type="checkbox" name="has_pension" <%=editSchool &&
                                                            editSchool.has_pension ? 'checked' : '' %>>
                                                        <span>Pansiyonu Var</span>
                                                    </label>
                                                    <label class="custom-checkbox">
                                                        <input type="checkbox" name="has_canteen" <%=editSchool &&
                                                            editSchool.has_canteen ? 'checked' : '' %>>
                                                        <span>Kantini Var</span>
                                                    </label>
                                                </div>
                                            </div>

                                            <div class="form-group">
                                                <label>Şifre <%= editSchool ? '(Değiştirmek istemiyorsanız boş bırakın)'
                                                        : '' %>
                                                </label>
                                                <input type="password" name="password" class="form-control"
                                                    <%=editSchool ? '' : 'required' %> placeholder="******">
                                            </div>

                                            <div class="form-actions">
                                                <button type="submit" class="btn-submit">
                                                    <% if(editSchool) { %>
                                                        <i class="fas fa-save"></i> Değişiklikleri Kaydet
                                                        <% } else { %>
                                                            <i class="fas fa-plus"></i> Okulu Kaydet
                                                            <% } %>
                                                </button>

                                                <% if(editSchool) { %>
                                                    <a href="/admin/schools" class="btn-cancel">
                                                        <i class="fas fa-times"></i> İptal
                                                    </a>
                                                    <% } %>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                <%- include('../layouts/footer') %>