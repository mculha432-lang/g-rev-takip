<%- include('../layouts/sef_header') %>

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/admin_task_detail.css">

<style>
  .back-btn { display: inline-flex; align-items: center; gap: 8px; color: #64748b; font-size: 13px; font-weight: 600; text-decoration: none; margin-bottom: 20px; transition: color .2s; }
  .back-btn:hover { color: #E31E24; }
  .report-btn { display: inline-flex; align-items: center; gap: 8px; padding: 9px 18px; background: #f0fdf4; color: #16a34a; border: 1.5px solid #bbf7d0; border-radius: 10px; font-size: 13px; font-weight: 600; text-decoration: none; transition: all .2s; }
  .report-btn:hover { background: #dcfce7; }
</style>

<a href="/sef/tasks" class="back-btn"><i class="fas fa-chevron-left"></i> Görev Listesine Dön</a>

<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; flex-wrap: wrap; gap: 12px;">
  <div>
    <h1 style="font-size: 22px; font-weight: 800; color: #1e293b; margin-bottom: 6px;"><%= task.title %></h1>
    <p style="font-size: 13px; color: #64748b;">
      <i class="fas fa-calendar-alt" style="margin-right: 5px;"></i>
      Son Tarih: <%= new Date(task.deadline).toLocaleDateString('tr-TR') %>
      &nbsp;·&nbsp;
      <i class="fas fa-school" style="margin-right: 5px;"></i>
      <%= assignments.length %> okul atandı
    </p>
  </div>
  <a href="/sef/tasks/<%= task.id %>/report/excel" class="report-btn">
    <i class="fas fa-file-excel"></i> Excel Rapor İndir
  </a>
</div>

<!-- Admin task_detail.ejs'nin aynı yapısını kullanıyoruz -->
<!-- Mevcut admin_task_detail.css ve JS kullanılır -->

<script type="application/json" id="messagesMapData"><%- messagesMapJSON %></script>
<script type="application/json" id="assignmentsData"><%- assignmentsJSON %></script>

<script>
  window.ME = '<%= user.id %>';
  window.TASK_ID = '<%= task.id %>';
  window.IS_SEF = true;
</script>

<!-- Atamalar Tablosu -->
<div style="background: #fff; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 2px 8px rgba(0,0,0,.04); overflow: hidden;">
  <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;">
    <h2 style="font-size: 16px; font-weight: 700; color: #1e293b; display: flex; align-items: center; gap: 8px;">
      <i class="fas fa-school" style="color: #E31E24;"></i> Okul Yanıtları
    </h2>
    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
      <input type="text" id="searchInput" placeholder="Okul ara..." 
        style="padding: 8px 14px; border: 1.5px solid #e2e8f0; border-radius: 10px; font-size: 13px; font-family: inherit; outline: none;"
        oninput="filterTable(this.value)">
    </div>
  </div>

  <div style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse;" id="assignmentsTable">
      <thead>
        <tr>
          <th style="background:#f8fafc; font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:.5px; padding:12px 18px; text-align:left; border-bottom:1px solid #e2e8f0;">Okul</th>
          <th style="background:#f8fafc; font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:.5px; padding:12px 18px; text-align:left; border-bottom:1px solid #e2e8f0;">Durum</th>
          <th style="background:#f8fafc; font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:.5px; padding:12px 18px; text-align:left; border-bottom:1px solid #e2e8f0;">Yanıt</th>
          <th style="background:#f8fafc; font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:.5px; padding:12px 18px; text-align:left; border-bottom:1px solid #e2e8f0;">Dosya</th>
          <th style="background:#f8fafc; font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:.5px; padding:12px 18px; text-align:left; border-bottom:1px solid #e2e8f0;">Form Cevapları</th>
        </tr>
      </thead>
      <tbody id="tableBody">
        <% assignments.forEach(a => {
          const statusLabels = { pending: 'Bekleyen', in_progress: 'Devam Ediyor', completed: 'Tamamlandı', rejected: 'İade Edildi', pending_approval: 'Onay Bekliyor' };
          const statusColors = { pending: '#f59e0b', in_progress: '#2563eb', completed: '#16a34a', rejected: '#dc2626', pending_approval: '#7c3aed' };
          const statusBg = { pending: '#fffbeb', in_progress: '#eff6ff', completed: '#f0fdf4', rejected: '#fef2f2', pending_approval: '#f5f3ff' };
        %>
        <tr data-name="<%= a.full_name.toLowerCase() %>">
          <td style="padding: 14px 18px; border-bottom: 1px solid #f1f5f9;">
            <div style="font-weight: 700; color: #1e293b; font-size: 14px;"><%= a.full_name %></div>
            <div style="font-size: 12px; color: #64748b; margin-top: 2px;"><%= a.username %></div>
          </td>
          <td style="padding: 14px 18px; border-bottom: 1px solid #f1f5f9;">
            <span style="background: <%= statusBg[a.status] || '#f8fafc' %>; color: <%= statusColors[a.status] || '#6b7280' %>; font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 20px; white-space: nowrap;">
              <%= statusLabels[a.status] || a.status %>
            </span>
          </td>
          <td style="padding: 14px 18px; border-bottom: 1px solid #f1f5f9; max-width: 200px;">
            <% if (a.response_note) { %>
              <p style="font-size: 13px; color: #374151; margin: 0; line-height: 1.5; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;"><%= a.response_note %></p>
            <% } else { %>
              <span style="font-size: 12px; color: #94a3b8;">—</span>
            <% } %>
          </td>
          <td style="padding: 14px 18px; border-bottom: 1px solid #f1f5f9;">
            <% if (a.files && a.files.length > 0) { %>
              <% a.files.forEach(f => { %>
                <a href="/uploads/responses/<%= f.file_path %>" target="_blank" 
                   style="display: flex; align-items: center; gap: 5px; font-size: 12px; color: #2563eb; text-decoration: none; margin-bottom: 4px;">
                  <i class="fas fa-download"></i> <%= f.original_name || f.file_path %>
                </a>
              <% }) %>
            <% } else if (a.response_file) { %>
              <a href="/uploads/responses/<%= a.response_file %>" target="_blank" 
                 style="display: flex; align-items: center; gap: 5px; font-size: 12px; color: #2563eb; text-decoration: none;">
                <i class="fas fa-download"></i> İndir
              </a>
            <% } else { %>
              <span style="font-size: 12px; color: #94a3b8;">—</span>
            <% } %>
          </td>
          <td style="padding: 14px 18px; border-bottom: 1px solid #f1f5f9;">
            <% if (a.fieldResponses && a.fieldResponses.length > 0) { %>
              <% a.fieldResponses.forEach(r => { %>
                <div style="margin-bottom: 6px;">
                  <span style="font-size: 11px; font-weight: 600; color: #64748b; display: block;"><%= r.field_label %>:</span>
                  <span style="font-size: 13px; color: #1e293b;">
                    <% 
                      let val = r.response_value;
                      if (val && val.startsWith('[')) {
                        try { val = JSON.parse(val).join(', '); } catch(e) {}
                      }
                    %>
                    <%= val || '—' %>
                  </span>
                </div>
              <% }) %>
            <% } else { %>
              <span style="font-size: 12px; color: #94a3b8;">—</span>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (assignments.length === 0) { %>
    <div style="text-align: center; padding: 60px; color: #94a3b8;">
      <i class="fas fa-school" style="font-size: 40px; margin-bottom: 14px; display: block; opacity: .3;"></i>
      <p style="font-weight: 600;">Bu göreve henüz okul atanmamış.</p>
    </div>
  <% } %>
</div>

<script>
  function filterTable(q) {
    document.querySelectorAll('#tableBody tr').forEach(row => {
      row.style.display = row.dataset.name && row.dataset.name.includes(q.toLowerCase()) ? '' : 'none';
    });
  }
</script>

<%- include('../layouts/footer') %>
