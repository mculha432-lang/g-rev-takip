<%- include('../layouts/sef_header') %>

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  .sef-page { padding: 0; }
  .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 28px; }
  .stat-card { background: #fff; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 18px; box-shadow: 0 2px 8px rgba(0,0,0,.04); transition: transform .2s, box-shadow .2s; }
  .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.08); }
  .stat-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
  .stat-icon.blue { background: #eff6ff; color: #2563eb; }
  .stat-icon.green { background: #f0fdf4; color: #16a34a; }
  .stat-icon.orange { background: #fff7ed; color: #ea580c; }
  .stat-icon.purple { background: #f5f3ff; color: #7c3aed; }
  .stat-info h3 { font-size: 28px; font-weight: 800; color: #1e293b; line-height: 1; }
  .stat-info p { font-size: 13px; color: #64748b; font-weight: 500; margin-top: 4px; }

  .section-title { font-size: 18px; font-weight: 700; color: #1e293b; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
  .task-list-table { width: 100%; background: #fff; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.04); }
  .task-list-table table { width: 100%; border-collapse: collapse; }
  .task-list-table th { background: #f8fafc; font-size: 12px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: .5px; padding: 14px 18px; text-align: left; border-bottom: 1px solid #e2e8f0; }
  .task-list-table td { padding: 14px 18px; font-size: 14px; color: #374151; border-bottom: 1px solid #f1f5f9; }
  .task-list-table tr:last-child td { border-bottom: none; }
  .task-list-table tr:hover td { background: #f8fafc; }

  .badge-active { background: #dcfce7; color: #16a34a; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
  .badge-expired { background: #fee2e2; color: #dc2626; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
  .progress-bar { height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden; min-width: 80px; }
  .progress-fill { height: 100%; background: linear-gradient(90deg, #16a34a, #4ade80); border-radius: 10px; transition: width .5s; }

  .btn { display: inline-flex; align-items: center; gap: 7px; padding: 9px 18px; border-radius: 10px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: all .2s; }
  .btn-primary { background: linear-gradient(135deg, #E31E24, #c41a1f); color: #fff; }
  .btn-primary:hover { background: linear-gradient(135deg, #c41a1f, #a31519); transform: translateY(-1px); }
  .btn-outline { background: transparent; color: #2563eb; border: 1.5px solid #93c5fd; }
  .btn-outline:hover { background: #eff6ff; }

  .welcome-banner { background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border-radius: 20px; padding: 28px 32px; margin-bottom: 28px; color: #fff; display: flex; align-items: center; justify-content: space-between; gap: 20px; }
  .welcome-banner h1 { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
  .welcome-banner p { font-size: 14px; color: #94a3b8; }
  .welcome-banner .icon-wrap { width: 64px; height: 64px; background: rgba(227,30,36,.15); border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 28px; color: #E31E24; flex-shrink: 0; }
</style>

<div class="sef-page">

  <!-- Welcome Banner -->
  <div class="welcome-banner">
    <div>
      <h1>Hoş Geldiniz, <%= user.full_name %> 👋</h1>
      <p>Şef panelinize genel bakış aşağıda yer almaktadır.</p>
    </div>
    <div class="icon-wrap"><i class="fas fa-user-tie"></i></div>
  </div>

  <!-- İstatistikler -->
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-icon blue"><i class="fas fa-tasks"></i></div>
      <div class="stat-info">
        <h3><%= totalTasks %></h3>
        <p>Toplam Görevim</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
      <div class="stat-info">
        <h3><%= activeTasks %></h3>
        <p>Aktif Görev</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon orange"><i class="fas fa-school"></i></div>
      <div class="stat-info">
        <h3><%= totalAssignments %></h3>
        <p>Toplam Atama</p>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon purple"><i class="fas fa-chart-pie"></i></div>
      <div class="stat-info">
        <h3>%<%= successRate %></h3>
        <p>Başarı Oranı</p>
      </div>
    </div>
  </div>

  <!-- Son Görevler -->
  <div class="section-title">
    <i class="fas fa-history" style="color: #E31E24;"></i> Son Görevlerim
    <a href="/sef/tasks" class="btn btn-outline" style="margin-left: auto; font-size: 12px; padding: 6px 14px;">
      Tümünü Gör <i class="fas fa-chevron-right"></i>
    </a>
  </div>

  <div class="task-list-table">
    <% if (!myTasks || myTasks.length === 0) { %>
      <div style="text-align:center; padding: 50px; color: #94a3b8;">
        <i class="fas fa-clipboard-list" style="font-size: 40px; margin-bottom: 14px; display: block;"></i>
        <p style="font-weight: 600;">Henüz görev oluşturmadınız.</p>
        <a href="/sef/tasks" class="btn btn-primary" style="margin-top: 16px;">
          <i class="fas fa-plus"></i> Yeni Görev Oluştur
        </a>
      </div>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Görev Adı</th>
          <th>Son Tarih</th>
          <th>Atanan Okul</th>
          <th>Tamamlanma</th>
          <th>Durum</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% myTasks.forEach(t => {
          const isExpired = new Date(t.deadline) < new Date();
          const rate = t.total_assignments > 0 ? Math.round((t.completed_assignments / t.total_assignments) * 100) : 0;
        %>
        <tr>
          <td style="font-weight: 600; color: #1e293b; max-width: 260px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= t.title %></td>
          <td style="font-size: 13px; color: #64748b;"><i class="fas fa-calendar-alt" style="color: #94a3b8; margin-right: 5px;"></i><%= new Date(t.deadline).toLocaleDateString('tr-TR') %></td>
          <td><%= t.total_assignments || 0 %> okul</td>
          <td>
            <div style="display: flex; align-items: center; gap: 8px;">
              <div class="progress-bar" style="flex: 1;">
                <div class="progress-fill" style="width: <%= rate %>%;"></div>
              </div>
              <span style="font-size: 12px; font-weight: 700; color: #374151;">%<%= rate %></span>
            </div>
          </td>
          <td><span class="<%= isExpired ? 'badge-expired' : 'badge-active' %>"><%= isExpired ? 'Süresi Doldu' : 'Aktif' %></span></td>
          <td>
            <a href="/sef/tasks/<%= t.id %>" class="btn btn-outline" style="padding: 6px 14px; font-size: 12px;">
              <i class="fas fa-eye"></i> İncele
            </a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

</div>

<%- include('../layouts/footer') %>
