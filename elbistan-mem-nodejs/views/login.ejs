<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elbistan İlçe MEM | Görev Takip Sistemi</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #E31E24;
            --text-dark: #2c3e50;
            --text-light: #ffffff;
            --bg-left: #f8f9fa;
            /* Slightly off-white for depth */
            /* Official Red Tones */
            --bg-right-start: #9b1b22;
            --bg-right-end: #e31e24;
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            height: 100vh;
            display: flex;
            overflow: hidden;
            background: var(--bg-left);
        }

        /* Left Side - Branding */
        .promo-section {
            flex: 1.2;
            background: var(--bg-left);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px;
            position: relative;
            z-index: 1;
        }

        /* Modern Abstract Background Pattern for Left Side */
        .promo-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image:
                radial-gradient(circle at 15% 50%, rgba(227, 30, 36, 0.05) 0%, transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(227, 30, 36, 0.03) 0%, transparent 25%);
            z-index: -1;
        }

        .promo-content {
            text-align: center;
            max-width: 500px;
            animation: fadeIn 1s ease-out;
        }

        .main-logo {
            width: 160px;
            height: auto;
            margin-bottom: 30px;
            /* Blend mode helps remove the 'white box' effect if the image is not transparent */
            mix-blend-mode: multiply;
            /* Remove drop-shadow to make it look flatter and more integrated */
            filter: none;
        }

        .promo-title {
            font-size: 32px;
            font-weight: 800;
            color: #1a1a1a;
            margin-bottom: 15px;
            letter-spacing: -0.5px;
            line-height: 1.2;
        }

        .promo-subtitle {
            font-size: 18px;
            color: #666;
            font-weight: 500;
            margin-bottom: 40px;
            position: relative;
            display: inline-block;
        }

        .promo-subtitle::after {
            content: '';
            position: absolute;
            left: 50%;
            bottom: -10px;
            transform: translateX(-50%);
            width: 40px;
            height: 3px;
            background: var(--primary-color);
            border-radius: 2px;
        }

        /* Right Side - Login Form */
        .login-section {
            flex: 1;
            background: linear-gradient(135deg, var(--bg-right-start) 0%, var(--bg-right-end) 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
            position: relative;
            box-shadow: -10px 0 30px rgba(0, 0, 0, 0.15);
        }

        /* Particle Canvas */
        #particles-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        .form-container {
            width: 100%;
            max-width: 380px;
            position: relative;
            z-index: 2;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: 45px 40px;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
            animation: slideIn 0.8s ease-out;
        }

        .form-header {
            text-align: center;
            margin-bottom: 35px;
            color: var(--text-light);
        }

        .form-header h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .input-group {
            margin-bottom: 25px;
        }

        .input-group label {
            display: block;
            color: rgba(255, 255, 255, 0.95);
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 500;
            padding-left: 5px;
        }

        .input-box {
            position: relative;
        }

        .input-box i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--primary-color);
            z-index: 10;
            font-size: 18px;
        }

        .input-box input {
            width: 100%;
            padding: 16px 16px 16px 50px;
            border: 2px solid transparent;
            border-radius: 12px;
            font-size: 15px;
            background: rgba(255, 255, 255, 0.95);
            color: #333;
            transition: all 0.3s ease;
            box-sizing: border-box;
            outline: none;
            font-weight: 500;
        }

        .input-box input:focus {
            background: #ffffff;
            border-color: rgba(255, 255, 255, 0.5);
            box-shadow: 0 0 0 5px rgba(255, 255, 255, 0.2);
        }

        .btn-submit {
            width: 100%;
            padding: 18px;
            border: none;
            border-radius: 12px;
            background: #ffffff;
            color: var(--primary-color);
            font-size: 16px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            margin-top: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            background: #f8f9fa;
        }

        .input-error-text {
            color: #ffcccc;
            font-size: 13px;
            font-weight: 500;
            margin-top: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .input-box input.has-error {
            border-color: #ffcccc;
            background: #fffafa;
        }

        .footer-copyright {
            position: absolute;
            bottom: 25px;
            width: 100%;
            text-align: center;
            color: rgba(255, 255, 255, 0.6);
            font-size: 13px;
            font-weight: 400;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        /* Responsive */
        @media (max-width: 900px) {
            body {
                flex-direction: column;
                overflow-y: auto;
            }

            .promo-section {
                flex: none;
                padding: 60px 20px;
                background: #fff;
            }

            .main-logo {
                width: 120px;
            }

            .promo-title {
                font-size: 24px;
            }

            .login-section {
                flex: none;
                min-height: 100vh;
                padding: 40px 20px;
            }
        }

        @media (max-width: 480px) {
            .promo-section {
                padding: 40px 15px;
            }

            .main-logo {
                width: 90px;
                margin-bottom: 20px;
            }

            .promo-title {
                font-size: 20px;
            }

            .promo-subtitle {
                font-size: 14px;
                margin-bottom: 20px;
            }

            .form-container {
                padding: 30px 20px;
            }

            .form-header h2 {
                font-size: 24px;
            }

            .input-box input {
                font-size: 15px;
            }
        }
    </style>
</head>

<body>

    <!-- Left Side: Branding -->
    <div class="promo-section">
        <div class="promo-content">
            <img src="/images/logo.png" alt="Elbistan MEM Logo" class="main-logo"
                onerror="this.src='https://cdn-icons-png.flaticon.com/512/3280/3280979.png'">
            <div class="promo-title">
                T.C.<br>
                MİLLÎ EĞİTİM BAKANLIĞI<br>
                Elbistan İlçe Müdürlüğü
            </div>
            <div class="promo-subtitle">
                Görev Takip ve Yönetim Sistemi
            </div>
        </div>
    </div>

    <!-- Right Side: Login Form -->
    <div class="login-section" id="login-section-container">
        <canvas id="particles-canvas"></canvas>

        <div class="form-container">
            <div class="form-header">
                <h2>Giriş Yap</h2>
            </div>

            <form action="/login" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="input-group">
                    <label>Kullanıcı Adı</label>
                    <div class="input-box">
                        <i class="fas fa-user-circle"></i>
                        <input type="text" name="username" class="<%= error ? 'has-error' : '' %>" required
                            placeholder="Kullanıcı adı veya kurum kodu" autocomplete="off">
                    </div>
                    <% if(error) { %>
                        <div class="input-error-text">
                            <i class="fas fa-exclamation-circle"></i>
                            <%= error %>
                        </div>
                        <% } %>
                </div>

                <div class="input-group">
                    <label>Şifre</label>
                    <div class="input-box">
                        <i class="fas fa-lock"></i>
                        <input type="password" name="password" id="password-input" required placeholder="••••••••">
                        <i class="fas fa-eye" id="togglePassword"
                            style="left: auto; right: 16px; cursor: pointer; color: var(--primary-color);"></i>
                    </div>
                </div>

                <div class="remember-me"
                    style="display: flex; align-items: center; gap: 8px; margin-bottom: 20px; color: rgba(255, 255, 255, 0.95); font-size: 14px; font-weight: 500;">
                    <input type="checkbox" name="remember" id="remember"
                        style="width: 16px; height: 16px; accent-color: var(--primary-color); cursor: pointer;">
                    <label for="remember" style="margin: 0; cursor: pointer;">Beni Hatırla</label>
                </div>

                <button type="submit" class="btn-submit">
                    Güvenli Giriş <i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <div class="footer-copyright">
                &copy; <%= new Date().getFullYear() %> Elbistan İlçe Milli Eğitim Müdürlüğü
            </div>
        </div>
    </div>


    <script>
        const canvas = document.getElementById('particles-canvas');
        const ctx = canvas.getContext('2d');
        const container = document.getElementById('login-section-container');

        let particlesArray;

        // Set canvas size to match the container
        function setCanvasSize() {
            canvas.width = container.offsetWidth;
            canvas.height = container.offsetHeight;
        }

        window.addEventListener('resize', () => {
            setCanvasSize();
            init();
        });

        // Create Particle Class
        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.directionX = (Math.random() * 1) - 0.5; // Speed X
                this.directionY = (Math.random() * 1) - 0.5; // Speed Y
                this.size = (Math.random() * 2) + 1;
                this.color = 'rgba(255, 255, 255, 0.4)';
            }

            // Draw method
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2, false);
                ctx.fillStyle = this.color;
                ctx.fill();
            }

            // Update method
            update() {
                // Check boundaries
                if (this.x > canvas.width || this.x < 0) {
                    this.directionX = -this.directionX;
                }
                if (this.y > canvas.height || this.y < 0) {
                    this.directionY = -this.directionY;
                }

                // Move particle
                this.x += this.directionX;
                this.y += this.directionY;

                // Draw particle
                this.draw();
            }
        }

        // Initialize particles
        function init() {
            particlesArray = [];
            let numberOfParticles = (canvas.width * canvas.height) / 15000; // Density
            for (let i = 0; i < numberOfParticles; i++) {
                particlesArray.push(new Particle());
            }
        }

        // Connect particles with lines
        function connect() {
            let opacityValue = 1;
            for (let a = 0; a < particlesArray.length; a++) {
                for (let b = a; b < particlesArray.length; b++) {
                    let distance = ((particlesArray[a].x - particlesArray[b].x) * (particlesArray[a].x - particlesArray[b].x)) +
                        ((particlesArray[a].y - particlesArray[b].y) * (particlesArray[a].y - particlesArray[b].y));

                    if (distance < (canvas.width / 7) * (canvas.height / 7)) {
                        opacityValue = 1 - (distance / 20000);
                        ctx.strokeStyle = 'rgba(255, 255, 255,' + opacityValue * 0.2 + ')';
                        ctx.lineWidth = 1;
                        ctx.beginPath();
                        ctx.moveTo(particlesArray[a].x, particlesArray[a].y);
                        ctx.lineTo(particlesArray[b].x, particlesArray[b].y);
                        ctx.stroke();
                    }
                }
            }
        }

        // Animation Loop
        function animate() {
            requestAnimationFrame(animate);
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (let i = 0; i < particlesArray.length; i++) {
                particlesArray[i].update();
            }
            connect();
        }

        // Start
        setCanvasSize();
        init();
        animate();

        // Password visibility toggle
        const togglePassword = document.querySelector('#togglePassword');
        const passwordInput = document.querySelector('#password-input');

        togglePassword.addEventListener('click', function () {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });
    </script>
</body>

</html>
<!-- Canli sunucu guncelleme testi -->