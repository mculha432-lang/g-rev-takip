<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Elbistan İlçe MEM — Şef Paneli</title>
    <link rel="icon" type="image/png" href="/images/logo.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #E31E24;
            --primary-hover: #C1181E;
            --sidebar-bg: #0f172a;
            --sidebar-hover: #1e293b;
            --body-bg: #f8fafc;
            --card-bg: #ffffff;
            --text: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: var(--body-bg); color: var(--text); min-height: 100vh; display: flex; }

        /* Sidebar */
        .sidebar {
            width: 260px; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh; position: fixed; left: 0; top: 0; padding: 20px;
            display: flex; flex-direction: column;
        }
        #sidebar-particles { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }
        .sidebar-brand, .nav-menu, .sidebar-footer { position: relative; z-index: 1; }
        .sidebar-brand {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 0 30px 0; border-bottom: 1px solid rgba(255,255,255,.1); margin-bottom: 30px;
        }
        .sidebar-brand img { width: 40px; height: 40px; border-radius: 10px; }
        .sidebar-brand h2 { color: white; font-size: 15px; font-weight: 700; }
        .sidebar-brand span { color: #94a3b8; font-size: 11px; display: block; margin-top: 2px; }

        /* Şef rozeti */
        .sef-badge {
            display: inline-flex; align-items: center; gap: 6px;
            background: linear-gradient(135deg, rgba(234,179,8,.2), rgba(234,179,8,.1));
            border: 1px solid rgba(234,179,8,.3); border-radius: 20px;
            padding: 4px 12px; font-size: 11px; font-weight: 700; color: #eab308;
            margin-bottom: 16px;
        }

        .nav-menu { list-style: none; flex: 1; }
        .nav-item { margin-bottom: 5px; }
        .nav-link {
            display: flex; align-items: center; gap: 12px; padding: 12px 15px;
            color: #94a3b8; text-decoration: none; border-radius: 10px;
            font-size: 14px; font-weight: 500; transition: all .2s;
        }
        .nav-link:hover, .nav-link.active { background: var(--sidebar-hover); color: white; transform: translateX(5px); }
        .nav-link.active { background: linear-gradient(135deg, #9b1b22 0%, #E31E24 100%); box-shadow: 0 4px 12px rgba(227,30,36,.3); }
        .nav-link i { width: 20px; text-align: center; }

        .sidebar-footer { border-top: 1px solid rgba(255,255,255,.1); padding-top: 20px; }
        .user-info { display: flex; align-items: center; gap: 12px; padding: 10px; background: var(--sidebar-hover); border-radius: 10px; margin-bottom: 15px; }
        .user-avatar { width: 40px; height: 40px; background: var(--primary); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; flex-shrink: 0; }
        .user-details h4 { color: white; font-size: 14px; font-weight: 600; }
        .user-details span { color: #eab308; font-size: 12px; }
        .btn-logout {
            display: flex; align-items: center; justify-content: center; gap: 8px;
            width: 100%; padding: 10px; background: rgba(239,68,68,.1); color: #ef4444;
            border: none; border-radius: 8px; font-size: 14px; font-weight: 600;
            cursor: pointer; text-decoration: none; transition: all .2s;
        }
        .btn-logout:hover { background: rgba(239,68,68,.2); }

        /* Main */
        .main-content { margin-left: 260px; flex: 1; padding: 30px; min-height: 100vh; }

        /* Mobile */
        .mobile-toggle {
            display: none; position: fixed; top: 15px; left: 15px; z-index: 1001;
            background: var(--primary); color: white; border: none; width: 45px; height: 45px;
            border-radius: 12px; font-size: 18px; cursor: pointer;
        }
        .sidebar-overlay {
            display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,.5); z-index: 999;
        }

        @media (max-width: 768px) {
            .mobile-toggle { display: flex; align-items: center; justify-content: center; }
            .sidebar { width: 280px; transform: translateX(-100%); transition: transform .3s ease; z-index: 1000; }
            .sidebar.active { transform: translateX(0); }
            .sidebar-overlay.active { display: block; }
            .main-content { margin-left: 0; padding: 80px 15px 20px; }
        }
    </style>
</head>
<body>
    <button class="mobile-toggle" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button>
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

    <aside class="sidebar" id="sidebar-container">
        <canvas id="sidebar-particles"></canvas>

        <div class="sidebar-brand">
            <img src="/images/logo.png" alt="Logo" onerror="this.style.display='none'">
            <div>
                <h2>Elbistan İlçe MEM</h2>
                <span>Görev Takip Sistemi</span>
            </div>
        </div>

        <div class="sef-badge">
            <i class="fas fa-user-tie"></i> Şef Paneli
        </div>

        <ul class="nav-menu">
            <li class="nav-item">
                <a href="/sef/dashboard" class="nav-link <%= activePage === 'dashboard' ? 'active' : '' %>">
                    <i class="fas fa-home"></i> <span>Genel Bakış</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/sef/tasks" class="nav-link <%= activePage === 'tasks' ? 'active' : '' %>">
                    <i class="fas fa-tasks"></i> <span>Görevlerim</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="/sef/profile" class="nav-link <%= activePage === 'profile' ? 'active' : '' %>">
                    <i class="fas fa-user-cog"></i> <span>Profilim</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <a href="/sef/profile" style="text-decoration: none;">
                <div class="user-info" style="cursor: pointer;">
                    <div class="user-avatar">
                        <%= user && user.full_name ? user.full_name.charAt(0).toUpperCase() : 'Ş' %>
                    </div>
                    <div class="user-details">
                        <h4><%= user ? user.full_name : 'Şef' %></h4>
                        <span><i class="fas fa-user-tie" style="font-size: 10px;"></i> Şef</span>
                    </div>
                </div>
            </a>
            <a href="/logout" class="btn-logout">
                <i class="fas fa-sign-out-alt"></i> <span>Çıkış Yap</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <script>
            function toggleSidebar() {
                document.querySelector('.sidebar').classList.toggle('active');
                document.querySelector('.sidebar-overlay').classList.toggle('active');
            }
            document.querySelectorAll('.nav-link').forEach(link => {
                link.addEventListener('click', () => {
                    if (window.innerWidth <= 768) {
                        document.querySelector('.sidebar').classList.remove('active');
                        document.querySelector('.sidebar-overlay').classList.remove('active');
                    }
                });
            });
        </script>
        <script>
            const sidebarCanvas = document.getElementById('sidebar-particles');
            const sidebarCtx = sidebarCanvas.getContext('2d');
            const sidebarContainer = document.getElementById('sidebar-container');
            let particlesArray;
            function setSidebarCanvasSize() { sidebarCanvas.width = sidebarContainer.offsetWidth; sidebarCanvas.height = sidebarContainer.offsetHeight; }
            window.addEventListener('resize', () => { setSidebarCanvasSize(); initParticles(); });
            class Particle {
                constructor() { this.x = Math.random() * sidebarCanvas.width; this.y = Math.random() * sidebarCanvas.height; this.directionX = (Math.random() * 0.5) - 0.25; this.directionY = (Math.random() * 0.5) - 0.25; this.size = (Math.random() * 1.5) + 0.5; this.color = 'rgba(255,255,255,0.15)'; }
                draw() { sidebarCtx.beginPath(); sidebarCtx.arc(this.x, this.y, this.size, 0, Math.PI * 2, false); sidebarCtx.fillStyle = this.color; sidebarCtx.fill(); }
                update() { if (this.x > sidebarCanvas.width || this.x < 0) this.directionX = -this.directionX; if (this.y > sidebarCanvas.height || this.y < 0) this.directionY = -this.directionY; this.x += this.directionX; this.y += this.directionY; this.draw(); }
            }
            function initParticles() { particlesArray = []; let n = (sidebarCanvas.width * sidebarCanvas.height) / 8000; for (let i = 0; i < n; i++) particlesArray.push(new Particle()); }
            function animateParticles() { requestAnimationFrame(animateParticles); sidebarCtx.clearRect(0, 0, sidebarCanvas.width, sidebarCanvas.height); particlesArray.forEach(p => p.update()); }
            setSidebarCanvasSize(); initParticles(); animateParticles();
        </script>
