# Elbistan İlçe MEM Görev Takip Sistemi - Environment Variables

# Sunucu Ayarları
PORT=3000
NODE_ENV=development

# Session Güvenliği
SESSION_SECRET=elbistan-ilce-mem-gizli-anahtar-2026-cok-guvenli-rastgele-string

# Veritabanı
DATABASE_PATH=./database.sqlite

# Loglama
LOG_LEVEL=info
LOG_DIR=./logs

# Güvenlik ve Rate Limit
LOGIN_LIMIT_MAX=100
LOGIN_LIMIT_WINDOW=1
