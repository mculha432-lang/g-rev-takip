# Elbistan İlçe MEM Görev Takip Sistemi - Environment Variables

# Sunucu Ayarları
PORT=3000
NODE_ENV=development
TZ=Europe/Istanbul

# Session Güvenliği
SESSION_SECRET=your_secret_key_here

# Veritabanı
DATABASE_PATH=./database.sqlite

# Loglama
LOG_LEVEL=info
LOG_DIR=./logs

# Güvenlik ve Rate Limit
LOGIN_LIMIT_MAX=5
LOGIN_LIMIT_WINDOW=15
